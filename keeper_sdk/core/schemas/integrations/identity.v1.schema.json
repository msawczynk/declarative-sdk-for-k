{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/msawczynk/declarative-sdk-for-k/schemas/integrations/identity.v1.json",
  "title": "keeper-integrations-identity.v1",
  "description": "Offline schema for identity integrations: domains, SCIM provisioning, SSO providers, and outbound email configuration. Apply remains unsupported until a safe Commander write/readback path is confirmed.",
  "x-keeper-live-proof": {
    "status": "preview-gated",
    "evidence": "tests/test_integrations_identity.py",
    "since_pin": "89047920a0df857e01fb59adcb0bfb9fa6db70bf",
    "notes": "W14 offline foundation: JSON Schema + typed models + field-level diff. Commander validate --online and apply remain upstream gaps."
  },
  "type": "object",
  "required": ["schema"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "keeper-integrations-identity.v1"
    },
    "domains": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/domain" }
    },
    "scim": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/scim" }
    },
    "sso_providers": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/sso_provider" }
    },
    "outbound_email": {
      "$ref": "#/$defs/outbound_email"
    }
  },
  "$defs": {
    "uid_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "record_ref": {
      "type": "string",
      "pattern": "^keeper-vault:records:[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "role_ref": {
      "type": "string",
      "pattern": "^keeper-enterprise:roles:[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "domain": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(\\.[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)+$"
        },
        "verified": {
          "type": "boolean",
          "default": false
        },
        "primary": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "scim": {
      "type": "object",
      "required": ["name", "uid_ref", "provider", "base_url", "token_uid_ref"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "uid_ref": { "$ref": "#/$defs/uid_ref" },
        "provider": {
          "type": "string",
          "enum": ["okta", "azure", "google", "generic"]
        },
        "sync_groups": {
          "type": "boolean",
          "default": false
        },
        "base_url": {
          "type": "string",
          "format": "uri",
          "minLength": 8
        },
        "token_uid_ref": { "$ref": "#/$defs/record_ref" }
      }
    },
    "sso_provider": {
      "type": "object",
      "required": ["name", "uid_ref", "type", "entity_id", "metadata_url"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "uid_ref": { "$ref": "#/$defs/uid_ref" },
        "type": {
          "type": "string",
          "enum": ["saml", "oidc"]
        },
        "entity_id": {
          "type": "string",
          "minLength": 1
        },
        "metadata_url": {
          "type": "string",
          "format": "uri",
          "minLength": 8
        },
        "default_role_uid_ref": { "$ref": "#/$defs/role_ref" }
      }
    },
    "outbound_email": {
      "type": "object",
      "required": ["from_address", "reply_to"],
      "additionalProperties": false,
      "properties": {
        "from_address": {
          "type": "string",
          "format": "email",
          "minLength": 3
        },
        "reply_to": {
          "type": "string",
          "format": "email",
          "minLength": 3
        },
        "smtp_uid_ref": { "$ref": "#/$defs/record_ref" }
      }
    }
  }
}
