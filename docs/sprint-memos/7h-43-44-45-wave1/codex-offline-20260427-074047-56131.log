+        allow_delete=allow_delete,
+        live_shared_folders=live[_SHARED_FOLDER_RESOURCE],
+        live_share_records=live[_RECORD_SHARE_RESOURCE],
+        live_share_folders=live[_SHARE_FOLDER_RESOURCE],
+    )
+
