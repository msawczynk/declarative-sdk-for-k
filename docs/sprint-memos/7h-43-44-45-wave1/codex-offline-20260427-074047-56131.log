keeper-sdk = "keeper_sdk.cli:main"

[tool.setuptools]
include-package-data = true

[tool.setuptools.packages.find]
include = ["keeper_sdk*"]
exclude = ["tests*"]

[tool.setuptools.package-data]
"keeper_sdk.core.schemas" = ["*.json", "**/*.json"]

[tool.mypy]
python_version = "3.11"
ignore_missing_imports = true
