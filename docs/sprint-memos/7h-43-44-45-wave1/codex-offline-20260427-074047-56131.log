+
+SCENARIO_NAME = "vaultSharingLifecycle"
+TITLE_PREFIX = "sdk-smoke"
+SF_UID = "sf-offline"
+MANIFEST_NAME = f"{TITLE_PREFIX}-{SCENARIO_NAME}"
+BLOCK_KEYS = ("folders", "shared_folders", "share_records", "share_folders")
