+        _SHARED_FOLDER_RESOURCE: [],
+        _RECORD_SHARE_RESOURCE: [],
+        _SHARE_FOLDER_RESOURCE: [],
+    }
+    for record in records:
+        if record.resource_type in rows:
+            rows[record.resource_type].append(_live_row(record))
+    return rows
+
