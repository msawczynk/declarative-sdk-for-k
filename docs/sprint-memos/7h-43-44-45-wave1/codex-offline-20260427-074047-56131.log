+def _replace_first_markerless_folder(records: list[LiveRecord]) -> list[LiveRecord]:
+    replaced = False
+    out: list[LiveRecord] = []
+    for record in records:
+        if record.resource_type != _SHARING_FOLDER_RESOURCE or replaced:
+            out.append(record)
