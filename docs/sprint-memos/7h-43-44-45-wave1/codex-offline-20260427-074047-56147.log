import os
import tempfile
from pathlib import Path

# reuse same importlib load pattern as test_pending_count.py:7-13

def write_marker(root: Path, name: str, text: str, mtime: float) -> None:
    p = root / name
    p.write_text(text, encoding="utf-8")
    os.utime(p, (mtime, mtime))

with tempfile.TemporaryDirectory() as td:
