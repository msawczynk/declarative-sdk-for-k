   307	                )
   308	                if m:
   309	                    trend.append(int(m.group(1)))
   310	            except OSError:
   311	                continue
   312	
   313	    out = {
   314	        "boot_ran_this_window": last_boot is not None and (boot_age_min or 1e9) < 240,
   315	        "boot_age_minutes": round(boot_age_min, 1) if boot_age_min is not None else None,
   316	        "journal_lines": len(journal_lines),
   317	        "lessons_lines": len(lessons_lines),
   318	        "lessons_size_bytes": lessons_size,
   319	        "lessons_added_today": lessons_today,
   320	        "pending_journal_items": pending_count,
   321	        "pending_trend": trend,
   322	        "lesson_tag_refs_in_session": len(lesson_tag_refs),
   323	        "lesson_tag_refs_unique": len(set(lesson_tag_refs)),
   324	    }
   325	    return out
   326	
   327	
   328	# ---------------------------------------------------- recommendation -------
   329	
   330	def recommend(tokens: dict, orch: dict, daybook: dict) -> list[str]:
   331	    """Map audit signals → next-optimisation recommendations.
   332	    Single source of truth for "what should the agent fix next?".
   333	    """
   334	    recs: list[str] = []
   335	
   336	    pd = tokens.get("prose_density_pct", 0)
   337	    if pd >= PROSE_DENSITY_FAIL:
   338	        recs.append(f"PROSE: density {pd}% > {PROSE_DENSITY_FAIL}%. Caveman/wenyan slipped — re-pin caveman skill at top of next reply.")
   339	    elif pd >= PROSE_DENSITY_WARN:
   340	        recs.append(f"prose: density {pd}% > {PROSE_DENSITY_WARN}%. Audit longest assistant messages; convert to bullets.")
   341	
   342	    bursts = tokens.get("prose_bursts", 0)
   343	    if bursts > 30:
   344	        recs.append(f"prose-bursts: {bursts} long-comma chains found. Trade for em-dash + line breaks.")
   345	
   346	    ac = tokens.get("assistant_chars", 0)
   347	    if ac > ASSISTANT_CHARS_BLOAT:
   348	        recs.append(f"BLOAT: assistant emitted {ac:,} chars. Per token-economy.mdc, target <{ASSISTANT_CHARS_BLOAT:,} per session — distill or split.")
   349	
   350	    sub = orch.get("subagent_transcripts", 0)
   351	    dr = orch.get("delegation_ratio", 0)
   352	    if sub == 0 and ac > 30000:
   353	        recs.append("ORCHESTRATION: 0 subagents but >30k assistant chars. Delegation rule violated — next substantive task: launch a Task subagent or codex run.")
   354	    elif dr < WORKER_RATIO_WARN and ac > 50000:
   355	        recs.append(f"orchestration: low delegation signal ({dr}/k chars). Pre-plan delegation budget for next sprint.")
   356	
   357	    if not daybook.get("boot_ran_this_window"):
   358	        recs.append("BOOT: agent_session_boot.sh did not fire in last 4 hours of this session. Pin it as the first tool call after compaction/continue.")
   359	
   360	    lessons_added = daybook.get("lessons_added_today", 0)
   361	    if lessons_added < LESSONS_MIN_PER_SESSION and ac > 20000:
   362	        recs.append(f"DAYBOOK: only {lessons_added} lesson(s) added today on {ac:,} assistant chars. Distill before reply: ≥1 tagged lesson per substantive sprint.")
   363	
   364	    refs = daybook.get("lesson_tag_refs_in_session", 0)
   365	    if refs == 0 and ac > 10000:
   366	        recs.append("DAYBOOK: no LESSON tags referenced in assistant output. Either LESSONS not consulted, or output didn't cite them — both signal stale daybook usage.")
   367	
   368	    pending = daybook.get("pending_journal_items", 0)
   369	    if pending > 8:
   370	        recs.append(f"daybook: {pending} pending JOURNAL items. Triage at next session boot.")
   371	
   372	    # Sprint 7h-13 enforcement: pending-watch. Pull prior 2 reviews from
   373	    # archive; if pending_journal_items has been non-decreasing across the
   374	    # last 3 sessions (this one + last 2), promote to a hard DAYBOOK alert
   375	    # so it sticks via prompt_resume_guard until the count drops.
   376	    trend = daybook.get("pending_trend") or []
   377	    if len(trend) >= 3 and all(trend[i] >= trend[i + 1] for i in range(len(trend) - 1)):
   378	        recs.append(
   379	            f"DAYBOOK: pending_journal_items non-decreasing over last "
   380	            f"{len(trend)} sessions (now={trend[0]}, prior={trend[1:]}); "
   381	            f"close at least one PENDING before next sprint or convert to "
   382	            f"explicit deferral (`# deferred to <date>` + LESSON entry)."
   383	        )
   384	
   385	    if not recs:
   386	        recs.append("ok: token economy + orchestration + daybook usefulness all within thresholds.")
   387	
   388	    return recs
   389	
   390	
   391	# ------------------------------------------------------------ output -------
   392	
   393	def render_markdown(tokens: dict, orch: dict, daybook: dict, recs: list[str]) -> str:
   394	    stamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
   395	    lines = [f"# agent_review_loop.py — digest {stamp}", ""]
   396	
   397	    lines.append("## next-optimisation (carry into next session)")
   398	    for r in recs:
   399	        lines.append(f"- {r}")
   400	    lines.append("")
   401	
   402	    lines.append("## token economy")
   403	    for k in ("assistant_chars", "assistant_words", "prose_density_pct",
   404	              "prose_bursts", "bullet_ratio", "lesson_tag_ref_count"):
   405	        if k in tokens:
   406	            lines.append(f"- {k}: {tokens[k]}")
   407	    lines.append("")
   408	
   409	    lines.append("## orchestration")
   410	    for k in ("subagent_transcripts", "delegation_keyword_mentions", "delegation_ratio"):
   411	        if k in orch:
   412	            lines.append(f"- {k}: {orch[k]}")
   413	    lines.append("")
   414	
   415	    lines.append("## daybook usefulness")
   416	    for k in ("boot_ran_this_window", "boot_age_minutes", "journal_lines",
   417	              "lessons_lines", "lessons_added_today",
   418	              "pending_journal_items", "lesson_tag_refs_in_session",
   419	              "lesson_tag_refs_unique"):
   420	        if k in daybook:
   421	            lines.append(f"- {k}: {daybook[k]}")
   422	    lines.append("")
   423	
   424	    if tokens.get("transcript"):
   425	        lines.append(f"_transcript: {tokens['transcript']}_")
   426	    lines.append("")
   427	    return "\n".join(lines)
   428	
   429	
   430	def main(argv: list[str]) -> int:
   431	    transcript = _newest_transcript()
   432	    tokens = audit_tokens(transcript)
   433	    orch = audit_orchestration(transcript)
   434	    daybook = audit_daybook(transcript)
   435	    recs = recommend(tokens, orch, daybook)
   436	
   437	    md = render_markdown(tokens, orch, daybook, recs)
   438	    print(md)
   439	
   440	    HOOK_LOG_DIR.mkdir(parents=True, exist_ok=True)
   441	    (HOOK_LOG_DIR / "review-latest.md").write_text(md, encoding="utf-8")
   442	    summary = {
   443	        "stamp": datetime.now(timezone.utc).isoformat(),
   444	        "tokens": tokens,
   445	        "orchestration": orch,
   446	        "daybook": daybook,
   447	        "recommendations": recs,
   448	    }
   449	    (HOOK_LOG_DIR / "review-latest.json").write_text(json.dumps(summary, indent=2), encoding="utf-8")
   450	
   451	    archive = HOOK_LOG_DIR / "review-archive"
   452	    archive.mkdir(exist_ok=True)
   453	    stamp_safe = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
   454	    (archive / f"review-{stamp_safe}.md").write_text(md, encoding="utf-8")
   455	
   456	    return 0
   457	
   458	
   459	if __name__ == "__main__":
   460	    sys.exit(main(sys.argv))

