     1	#!/usr/bin/env bash
     2	# agent_session_boot.sh — one-command session/continuation boot ritual.
     3	#
     4	# Why: replaces the three-tool-call boot block (head JOURNAL, tail LESSONS, git status)
     5	# with a single command. Runs at session start, after compaction, after `continue`/`pick up`
     6	# user prompts, after long worker returns. Output is intentionally compact + greppable so
     7	# downstream tools (or hooks) can parse it.
     8	#
     9	# Canonical location: ~/.cursor-daybook-sync/scripts/ — synced via the daybook git mirror.
    10	#
    11	# Usage: bash ~/.cursor-daybook-sync/scripts/agent_session_boot.sh [SECTIONS]
    12	#   default: head-journal + tail-lessons + git-status + scaffold-pointer
    13	#   pass `compact` for a 1-screen variant (head-30, tail-20)
    14	#
    15	# Exit code: always 0 — informational only. Never blocks an agent.
    16	
    17	set -u
    18	mode="${1:-default}"
    19	
    20	JOURNAL="${JOURNAL:-/Users/martin/Downloads/JOURNAL.md}"
    21	LESSONS="${LESSONS:-/Users/martin/Downloads/LESSONS.md}"
    22	SCAFFOLD="${SCAFFOLD:-/Users/martin/Downloads/SCAFFOLD.md}"
    23	LAB_SCAFFOLD="${LAB_SCAFFOLD:-/Users/martin/Downloads/Cursor tests/SCAFFOLD.md}"
    24	
    25	case "$mode" in
    26	  compact) head_n=20; tail_n=15 ;;
    27	  *)       head_n=30; tail_n=25 ;;
    28	esac
    29	
    30	echo "=== AGENT SESSION BOOT ($(date -u +%FT%TZ)) ==="
    31	echo ""
    32	
    33	# Surface the previous session's auto-review recommendations FIRST so the
    34	# agent picks up open optimisations before re-reading JOURNAL/LESSONS. This
    35	# is how the review loop actually closes — last session's stop hook produced
    36	# ~/.cursor/hooks-log/review-latest.md; this session reads it.
    37	REVIEW_LATEST="${HOOK_LOG_DIR:-$HOME/.cursor/hooks-log}/review-latest.md"
    38	if [ -f "$REVIEW_LATEST" ]; then
    39	  echo "## prior-session auto-review (next-optimisation carry-over)"
    40	  awk '/^## next-optimisation/{flag=1;next}/^##/{flag=0}flag' "$REVIEW_LATEST" \
    41	    | head -10
    42	  echo ""
    43	fi
    44	
    45	echo "## SCAFFOLD pointer"
    46	if [ -f "$SCAFFOLD" ]; then
    47	  echo "Workspace SCAFFOLD: $SCAFFOLD"
    48	  head -1 "$SCAFFOLD" 2>/dev/null
    49	fi
    50	if [ -f "$LAB_SCAFFOLD" ]; then
    51	  echo "Lab SCAFFOLD: $LAB_SCAFFOLD"
    52	fi
    53	echo ""
    54	
    55	echo "## JOURNAL.md (head $head_n)"
    56	if [ -f "$JOURNAL" ]; then
    57	  head -n "$head_n" "$JOURNAL"
    58	else
    59	  echo "MISSING: $JOURNAL"
    60	fi
    61	echo ""
    62	
    63	echo "## LESSONS.md (tail $tail_n — newest first via reverse)"
    64	if [ -f "$LESSONS" ]; then
    65	  tail -n "$tail_n" "$LESSONS"
    66	else
    67	  echo "MISSING: $LESSONS"
    68	fi
    69	echo ""
    70	
    71	echo "## git status (cwd=$(pwd))"
    72	if git rev-parse --git-dir >/dev/null 2>&1; then
    73	  git status --short --branch | head -20
    74	else
    75	  echo "(not a git repo at cwd)"
    76	fi
    77	echo ""
    78	
    79	echo "## reminders"
    80	echo "- caveman-ultra in chat; wenyan-ultra in thinking; daybook before tools."
    81	echo "- delegate scoped offline work to Codex / cheap workers; parent reviews."
    82	echo "- before any keeper login → bash ~/.cursor-daybook-sync/scripts/ksm_login_preflight.sh"
    83	echo "- before any 'done' claim → bash ~/.cursor-daybook-sync/scripts/agent_pre_claim.sh"
    84	echo "- 3-patch stop rule; never echo secrets/env/TOTP."
    85	echo "=== END BOOT ==="
    86	
    87	exit 0

