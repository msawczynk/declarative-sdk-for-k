    43	class FakeFileKeyValueStorage:
    44	    """Captures the config path passed to the KSM storage wrapper."""
    45	
    46	    def __init__(self, path: str) -> None:
    47	        self.path = path
    48	
    49	
    50	class FakeSecretsManager:
    51	    """Fake ``SecretsManager`` with class-level records for easy patching.
    52	
    53	    ``get_secrets_calls`` lets tests assert how many fetch attempts the
    54	    bootstrap verify loop made; ``visibility_delay`` simulates the
    55	    add_app_share → KSM-client propagation race by hiding the records
    56	    for the first N ``get_secrets`` calls.
    57	    """
    58	
    59	    records: dict[str, FakeRecord] = {}
    60	    init_calls: list[Any] = []
    61	    get_secrets_calls: int = 0
    62	    visibility_delay: int = 0
    63	
    64	    def __init__(self, *, config: Any, token: str | None = None, **kwargs: Any) -> None:
    65	        _ = kwargs
    66	        self.config = config
    67	        self.__class__.init_calls.append({"config": config, "token_supplied": token is not None})
    68	        if token is not None and getattr(config, "path", None):
    69	            Path(config.path).write_text('{"fake":"ksm-config"}', encoding="utf-8")
    70	
    71	    def get_secrets(self, uids: list[str]) -> list[FakeRecord]:
    72	        cls = self.__class__
    73	        cls.get_secrets_calls += 1
    74	        if cls.get_secrets_calls <= cls.visibility_delay:
    75	            return []
    76	        return [self.records[uid] for uid in uids if uid in self.records]
    77	
    78	
    79	def install_fake_ksm_core(
    80	    monkeypatch: Any,
    81	    records: dict[str, FakeRecord],
    82	    *,
    83	    visibility_delay: int = 0,
    84	) -> type[FakeSecretsManager]:
    85	    """Install fake KSM modules into ``sys.modules`` for one test."""
    86	    FakeSecretsManager.records = dict(records)
    87	    FakeSecretsManager.init_calls = []
    88	    FakeSecretsManager.get_secrets_calls = 0
    89	    FakeSecretsManager.visibility_delay = visibility_delay
    90	
    91	    core = types.ModuleType("keeper_secrets_manager_core")
    92	    core.SecretsManager = FakeSecretsManager
    93	    storage = types.ModuleType("keeper_secrets_manager_core.storage")
    94	    storage.FileKeyValueStorage = FakeFileKeyValueStorage
    95	
    96	    monkeypatch.setitem(sys.modules, "keeper_secrets_manager_core", core)
    97	    monkeypatch.setitem(sys.modules, "keeper_secrets_manager_core.storage", storage)
    98	    return FakeSecretsManager

