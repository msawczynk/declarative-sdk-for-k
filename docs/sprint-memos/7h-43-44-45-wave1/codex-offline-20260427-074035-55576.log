  2240	def _is_retryable_keeper_session_error(exc: BaseException) -> bool:
  2241	    """True when *exc* or its ``__cause__`` chain signals a refreshable session."""
  2242	    parts: list[str] = []
  2243	    cur: BaseException | None = exc
  2244	    for _ in range(8):
  2245	        if cur is None:
  2246	            break
  2247	        result_code = getattr(cur, "result_code", None)
  2248	        if isinstance(result_code, str) and result_code == _SESSION_EXPIRED_CODE:
  2249	            return True
  2250	        parts.append(f"{type(cur).__name__}: {cur}")
  2251	        cur = cur.__cause__ or getattr(cur, "original_error", None)
  2252	    text = "\n".join(parts).casefold()
  2253	    return _SESSION_EXPIRED_CODE in text or ("session token" in text and "expired" in text)
  2254	
