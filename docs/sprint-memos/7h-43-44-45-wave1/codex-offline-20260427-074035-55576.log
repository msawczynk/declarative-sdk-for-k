  2256	def _is_retryable_keeper_session_text(stdout: str | None, stderr: str | None) -> bool:
  2257	    text = f"{stdout or ''}\n{stderr or ''}".casefold()
  2258	    return _SESSION_EXPIRED_CODE in text or ("session token" in text and "expired" in text)
