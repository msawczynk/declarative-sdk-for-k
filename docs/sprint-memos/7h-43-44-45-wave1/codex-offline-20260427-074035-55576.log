  2987	                return _non_empty_str(user.get("type")) or "pamUser", _non_empty_str(
  2988	                    user.get("title")
  2989	                )
  2990	    for user in source.get("users") or []:
  2991	        if isinstance(user, Mapping) and user.get("uid_ref") == uid_ref:
  2992	            return _non_empty_str(user.get("type")) or "pamUser", _non_empty_str(user.get("title"))
  2993	    return None, None
