+    *,
+    manifest_source: dict[str, Any] | None = None,
+    stdout: str = "",
+) -> CommanderCliProvider:
+    monkeypatch.setattr(
+        commander_cli_mod.shutil,
+        "which",
+        lambda _bin: "/usr/bin/keeper",
+    )
+    monkeypatch.setattr(CommanderCliProvider, "_run_cmd", lambda self, args: stdout)
