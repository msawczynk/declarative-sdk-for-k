  2806	def _inverse_on_off(value: Any) -> str | None:
  2807	    if value is None:
  2808	        return None
  2809	    if isinstance(value, bool):
  2810	        return "off" if value else "on"
  2811	    if value == "on":
  2812	        return "off"
  2813	    if value == "off":
  2814	        return "on"
  2815	    return str(value)
