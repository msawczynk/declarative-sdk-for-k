  2616	class _RotationRefResolver:
  2617	    def __init__(self, *, plan: Plan | None, live_records: list[LiveRecord]) -> None:
  2618	        self._plan_by_ref: dict[str, Change] = {}
  2619	        self._plan_by_title: dict[tuple[str, str], Change] = {}
  2620	        if plan is not None:
  2621	            for change in plan.changes:
  2622	                if change.uid_ref:
  2623	                    self._plan_by_ref[change.uid_ref] = change
  2624	                self._plan_by_title[(change.resource_type, change.title)] = change
  2625	
  2626	        self._live_by_ref: dict[str, list[LiveRecord]] = {}
  2627	        self._live_by_title, self._live_by_any_title = _index_live_records_for_title_matching(
  2628	            live_records
  2629	        )
  2630	        for live in live_records:
  2631	            marker_ref = _non_empty_str((live.marker or {}).get("uid_ref"))
  2632	            if marker_ref:
  2633	                self._live_by_ref.setdefault(marker_ref, []).append(live)
  2634	
  2635	    def resolve(
  2636	        self,
  2637	        *,
  2638	        uid_ref: str | None,
  2639	        title: str | None,
  2640	        resource_type: str,
  2641	        role: str,
  2642	    ) -> str:
  2643	        if uid_ref:
  2644	            uid = self._resolve_live_ref(uid_ref, role)
  2645	            if uid:
  2646	                return uid
  2647	            change = self._plan_by_ref.get(uid_ref)
  2648	            if change and change.keeper_uid:
  2649	                return change.keeper_uid
  2650	
  2651	        if title:
  2652	            uid = self._resolve_live_title(resource_type, title, role)
  2653	            if uid:
  2654	                return uid
  2655	            change = self._plan_by_title.get((resource_type, title))
  2656	            if change and change.keeper_uid:
  2657	                return change.keeper_uid
  2658	
  2659	        ident = f"uid_ref='{uid_ref}'" if uid_ref else f"title='{title}'"
  2660	        raise ValueError(
  2661	            f"missing live {role} ({ident}, type={resource_type}); "
  2662	            "run import/apply first, then pass discovered live records with Keeper UIDs"
  2663	        )
  2664	
  2665	    def _resolve_live_ref(self, uid_ref: str, role: str) -> str | None:
  2666	        matches = self._live_by_ref.get(uid_ref, [])
  2667	        if len(matches) > 1:
  2668	            raise ValueError(
  2669	                f"duplicate live {role} match for uid_ref '{uid_ref}': "
  2670	                f"{[item.keeper_uid for item in matches]}"
  2671	            )
  2672	        return matches[0].keeper_uid if matches else None
  2673	
  2674	    def _resolve_live_title(self, resource_type: str, title: str, role: str) -> str | None:
  2675	        matches = _live_matches_by_identity(
  2676	            live_by_key=self._live_by_title,
  2677	            live_by_title=self._live_by_any_title,
  2678	            resource_type=resource_type,
  2679	            title=title,
  2680	        )
  2681	        if len(matches) > 1:
  2682	            raise ValueError(
  2683	                f"duplicate live {role} match for title '{title}' ({resource_type}): "
  2684	                f"{[item.keeper_uid for item in matches]}"
  2685	            )
  2686	        return matches[0].keeper_uid if matches else None
  2687	
  2688	
  2689	def _index_live_records_for_title_matching(
  2690	    live_records: list[LiveRecord],
  2691	) -> tuple[dict[tuple[str, str], list[LiveRecord]], dict[str, list[LiveRecord]]]:
  2692	    live_by_key: dict[tuple[str, str], list[LiveRecord]] = {}
  2693	    live_by_title: dict[str, list[LiveRecord]] = {}
  2694	    for live in live_records:
  2695	        live_by_key.setdefault((live.resource_type, live.title), []).append(live)
  2696	        if live.title:
  2697	            live_by_title.setdefault(live.title, []).append(live)
  2698	    return live_by_key, live_by_title
  2699	
  2700	
  2701	def _live_matches_by_identity(
  2702	    *,
  2703	    live_by_key: dict[tuple[str, str], list[LiveRecord]],
  2704	    live_by_title: dict[str, list[LiveRecord]],
  2705	    resource_type: str,
  2706	    title: str,
  2707	) -> list[LiveRecord]:
  2708	    exact = live_by_key.get((resource_type, title), [])
  2709	    if exact:
  2710	        return exact
  2711	    return live_by_title.get(title, []) if title else []
