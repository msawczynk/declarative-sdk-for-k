+def test_in_process_read_wrappers_wrap_session_errors(
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    """Covers commander_cli.py lines 1943-1944, 2095-2096, and 2139-2140."""
+    provider = _provider(monkeypatch)
