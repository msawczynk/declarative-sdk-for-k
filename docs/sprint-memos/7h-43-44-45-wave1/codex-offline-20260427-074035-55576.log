  3021	def _build_pam_rotation_edit_args(
  3022	    *,
  3023	    record_uid: str,
  3024	    settings: Any,
  3025	    resource_uid: str | None = None,
  3026	    config_uid: str | None = None,
  3027	    admin_uid: str | None = None,
  3028	    schedule_only: bool = False,
  3029	    force: bool = True,
  3030	) -> list[str]:
  3031	    """Map declarative rotation settings to Commander's `pam rotation edit` argv.
  3032	
  3033	    Pure helper only. `apply_plan` calls it only behind the Commander-only
  3034	    `DSK_EXPERIMENTAL_ROTATION_APPLY` opt-in.
  3035	    """
  3036	    data = _model_dump_dict(settings)
  3037	    args = ["pam", "rotation", "edit", "--record", record_uid]
  3038	    if config_uid:
  3039	        args += ["--config", config_uid]
  3040	    if resource_uid:
  3041	        args += ["--resource", resource_uid]
  3042	    if admin_uid:
  3043	        args += ["--admin-user", admin_uid]
  3044	    if data.get("rotation"):
  3045	        args += ["--rotation-profile", str(data["rotation"])]
  3046	    args += _rotation_schedule_args(data.get("schedule"))
  3047	    if data.get("password_complexity"):
  3048	        args += ["--complexity", str(data["password_complexity"])]
  3049	    enabled = str(data.get("enabled") or "").strip().lower()
  3050	    if enabled == "on":
  3051	        args.append("--enable")
  3052	    elif enabled == "off":
  3053	        args.append("--disable")
  3054	    if schedule_only:
  3055	        args.append("--schedule-only")
  3056	    if force:
  3057	        args.append("--force")
  3058	    return args
