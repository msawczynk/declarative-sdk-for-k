+    provider._keeper_params = params
+
+    output = provider._run_pam_project_in_process(
+        [
+            "pam",
+            "project",
+            "extend",
+            "--config",
+            "Config",
+            "--file",
+            "/tmp/manifest.json",
+            "--dry-run",
+        ]
+    )
+
+    assert output.strip() == "extend ok"
+    assert seen == [
+        (
+            params,
+            {"config": "Config", "file_name": "/tmp/manifest.json", "dry_run": True},
+        )
+    ]
