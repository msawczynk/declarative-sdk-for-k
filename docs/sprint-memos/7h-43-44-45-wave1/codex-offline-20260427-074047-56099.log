@dataclass(frozen=True, kw_only=True)
class SmokeProfile:
    id: str
    target_email: str
    ksm_config: Path
    admin_commander_config: Path
    sdktest_commander_config: Path
    keeper_server: str = "keepersecurity.com"
    channel_name: str = "sdk-declarative"
    password: str
