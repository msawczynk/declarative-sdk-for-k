_SHARING_REF_RE = re.compile(
    r"^keeper-vault-sharing:(?P<block>folders|shared_folders):(?P<uid_ref>.+)$"
)
_RECORD_REF_RE = re.compile(r"^keeper-vault:records:(?P<uid_ref>.+)$")


