    spec = smoke_scenarios.get("pamUserNested")

    class _Record:
        resource_type = "pamUser"
        title = "smoke-user"
        payload: dict[str, Any] = {}

    with pytest.raises(AssertionError, match="login"):
        spec.verify([_Record()])

