def _check_marker_supported(
    marker: dict[str, Any],
    *,
    uid_ref: str | None,
    resource_type: str = _SHARING_FOLDER_RESOURCE,
) -> None:
    if marker.get("manager") != MANAGER_NAME:
        return
    if marker.get("version") not in (None, MARKER_VERSION):
        raise OwnershipError(
