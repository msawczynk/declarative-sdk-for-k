) -> dict[str, object]:
    data = dict(payload or _grantee_share())
    uid_ref = str(data["uid_ref"])
    data["keeper_uid"] = f"live-{uid_ref}"
    data["marker"] = marker if marker is not None else _marker(uid_ref)
    return data


