                    "add",
                    "--app",
                    app_uid,
                    "--secret",
                    folder_uid,
                    "--editable",
                ]
            )
        except CapabilityError as exc:
            text = "\n".join(
                str(value) for value in (exc.context or {}).values() if isinstance(value, str)
            ).casefold()
            if "already" not in text:
                raise

