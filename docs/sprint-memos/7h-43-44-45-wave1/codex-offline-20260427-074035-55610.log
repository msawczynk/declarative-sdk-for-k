@@ -0,0 +1,38 @@
+schema: keeper-vault-sharing.v1
+
+# Folder topology with three private folders and two shared folders.
+#
+# Run:
+#   dsk validate examples/sharing-folders-shared.yaml
+#   dsk plan     examples/sharing-folders-shared.yaml --provider mock --json
+
+folders:
+  - uid_ref: folder.engineering
+    path: /Engineering
+    color: blue
+
+  - uid_ref: folder.engineering.platform
+    path: /Engineering/Platform
+    parent_folder_uid_ref: keeper-vault-sharing:folders:folder.engineering
+    color: green
+
+  - uid_ref: folder.operations
+    path: /Operations
+    color: orange
+
+shared_folders:
+  - uid_ref: sf.engineering
+    path: /Shared/Engineering
+    defaults:
+      manage_users: false
+      manage_records: true
+      can_edit: true
+      can_share: false
+
+  - uid_ref: sf.operations
+    path: /Shared/Operations
+    defaults:
+      manage_users: true
+      manage_records: true
+      can_edit: false
+      can_share: false
diff --git a/examples/sharing-grantees.yaml b/examples/sharing-grantees.yaml
new file mode 100644
index 0000000000000000000000000000000000000000..b0f7b91a360712644772a753c008789e263c7f14
--- /dev/null
+++ b/examples/sharing-grantees.yaml
@@ -0,0 +1,69 @@
+schema: keeper-vault-sharing.v1
+
+# Shared-folder grants demonstrating user, team, record, and default share rows.
+#
+# Run:
+#   dsk validate examples/sharing-grantees.yaml
+#   dsk plan     examples/sharing-grantees.yaml --provider mock --json
+
+shared_folders:
+  - uid_ref: sf.platform
+    path: /Shared/Platform
+    defaults:
+      manage_users: false
+      manage_records: true
+      can_edit: true
+      can_share: false
+
+share_records:
+  - uid_ref: share.record.admin.alice
+    record_uid_ref: keeper-vault:records:rec.login.web-admin
+    user_email: alice@example.com
+    permissions:
+      can_edit: false
+      can_share: false
+
+share_folders:
+  - kind: grantee
+    uid_ref: sf.platform.user.alice
+    shared_folder_uid_ref: keeper-vault-sharing:shared_folders:sf.platform
+    grantee:
+      kind: user
+      user_email: alice@example.com
+    permissions:
+      manage_records: true
+      manage_users: false
+
+  - kind: grantee
+    uid_ref: sf.platform.team.ops
+    shared_folder_uid_ref: keeper-vault-sharing:shared_folders:sf.platform
+    grantee:
+      kind: team
+      team_uid_ref: keeper-enterprise:teams:team.ops
+    permissions:
+      manage_records: true
+      manage_users: true
+
+  - kind: record
+    uid_ref: sf.platform.record.web-admin
+    shared_folder_uid_ref: keeper-vault-sharing:shared_folders:sf.platform
+    record_uid_ref: keeper-vault:records:rec.login.web-admin
+    permissions:
+      can_edit: true
+      can_share: false
+
+  - kind: default
+    uid_ref: sf.platform.default.grantee
+    shared_folder_uid_ref: keeper-vault-sharing:shared_folders:sf.platform
+    target: grantee
+    permissions:
+      manage_records: true
+      manage_users: false
+
+  - kind: default
+    uid_ref: sf.platform.default.record
+    shared_folder_uid_ref: keeper-vault-sharing:shared_folders:sf.platform
+    target: record
+    permissions:
+      can_edit: true
+      can_share: false
diff --git a/examples/vault-attachments.yaml b/examples/vault-attachments.yaml
new file mode 100644
index 0000000000000000000000000000000000000000..6ff516a6436c83382d8bc4981aa73c2bc0b378cb
--- /dev/null
+++ b/examples/vault-attachments.yaml
@@ -0,0 +1,36 @@
+schema: keeper-vault.v1
+
+# Attachment declarations attached to a login record. Paths are examples only;
+# offline validate does not read source_path.
+#
+# Run:
+#   dsk validate examples/vault-attachments.yaml
+
+records:
+  - uid_ref: rec.runbook.login
+    type: login
+    title: "Example Runbook Login"
+    fields:
+      - type: login
+        label: Login
+        value: ["runbook@example.invalid"]
+      - type: password
+        label: Password
+        value: ["example-password"]
+
+attachments:
+  - uid_ref: att.runbook.pdf
+    record_uid_ref: rec.runbook.login
+    source_path: ./attachments/runbook.pdf
+    name: runbook.pdf
+    title: "Operational Runbook"
+    mime_type: application/pdf
+    content_sha256: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
+
+  - uid_ref: att.runbook.txt
+    record_uid_ref: rec.runbook.login
+    source_path: ./attachments/recovery-steps.txt
+    name: recovery-steps.txt
+    title: "Recovery Steps"
+    mime_type: text/plain
+    content_sha256: abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
diff --git a/examples/vault-record-types.yaml b/examples/vault-record-types.yaml
new file mode 100644
index 0000000000000000000000000000000000000000..36a14f5d8e75ed86d4bb6f20a8af5ca6b594cee9
--- /dev/null
+++ b/examples/vault-record-types.yaml
@@ -0,0 +1,40 @@
+schema: keeper-vault.v1
+
+# Custom record-type definitions. These are schema-validated offline; provider
+# lifecycle coverage for record_types[] is intentionally separate from login L1.
+#
+# Run:
+#   dsk validate examples/vault-record-types.yaml
+
+record_types:
+  - uid_ref: rt.service-account
+    scope: enterprise
+    record_type_id: 3001001
+    content:
+      $id: serviceAccount
+      categories: ["login"]
+      description: "Service account credential"
+      fields:
+        - $ref: login
+          label: Username
+          required: true
+        - $ref: password
+          label: Password
+          required: true
+        - $ref: host
+          label: Endpoint
+
+  - uid_ref: rt.break-glass-admin
+    scope: enterprise
+    record_type_id: 3001002
+    content:
+      $id: breakGlassAdmin
+      categories: ["login", "admin"]
+      description: "Emergency access credential"
+      fields:
+        - $ref: login
+          required: true
+        - $ref: password
+          required: true
+        - $ref: securityQuestion
+          label: Recovery Question
diff --git a/examples/vault-records.yaml b/examples/vault-records.yaml
new file mode 100644
index 0000000000000000000000000000000000000000..6409f329e043a286bc394ef2229850741045cfbb
--- /dev/null
+++ b/examples/vault-records.yaml
@@ -0,0 +1,99 @@
+schema: keeper-vault.v1
+
+# Five validate-clean vault records. The current CLI validator typed-loads
+# keeper-vault.v1 through the L1 login lifecycle, so these stay type: login
+# while demonstrating field payloads commonly needed for login, credit-card,
+# database-credential, server-credential, and custom record examples.
+#
+# Run:
+#   dsk validate examples/vault-records.yaml
+#   dsk plan     examples/vault-records.yaml --provider mock --json
+
+records:
+  - uid_ref: rec.login.web-admin
+    type: login
+    title: "Example Web Admin"
+    fields:
+      - type: login
+        label: Login
+        value: ["web-admin@example.invalid"]
+      - type: password
+        label: Password
+        value: ["example-password"]
+      - type: url
+        label: URL
+        value: ["https://admin.example.invalid"]
+
+  - uid_ref: rec.credit-card.ops
+    type: login
+    title: "Example Credit Card"
+    fields:
+      - type: paymentCard
+        label: Payment Card
+        value:
+          - cardNumber: "test-card-number"
+            cardExpirationDate: "01/2030"
+            cardSecurityCode: "000"
+    custom:
+      - type: text
+        label: Cost Center
+        value: ["operations"]
+
+  - uid_ref: rec.database.credentials
+    type: login
+    title: "Example Database Credentials"
+    fields:
+      - type: login
+        label: Username
+        value: ["orders_app"]
+      - type: password
+        label: Password
+        value: ["example-db-password"]
+      - type: host
+        label: Host
+        value:
+          - hostName: db.example.invalid
+            port: 5432
+    custom:
+      - type: text
+        label: Database
+        value: ["orders"]
+
+  - uid_ref: rec.server.credentials
+    type: login
+    title: "Example Server Credentials"
+    fields:
+      - type: login
+        label: Username
+        value: ["svc-deploy"]
+      - type: host
+        label: Host
+        value:
+          - hostName: app.example.invalid
+            port: "22"
+      - type: keyPair
+        label: SSH Key
+        value:
+          - publicKey: "ssh-ed25519 example-public-key"
+            privateKey: "example-private-key"
+
+  - uid_ref: rec.custom.asset
+    type: login
+    title: "Example Custom Asset"
+    notes: "Custom metadata-only example with typed custom fields."
+    fields:
+      - type: text
+        label: Asset Tag
+        value: ["asset-12345"]
+    custom:
+      - type: name
+        label: Owner
+        value:
+          - first: Example
+            last: Owner
+      - type: phone
+        label: Support Phone
+        value:
+          - region: US
+            number: "5550100"
+            type: Work

diff --git a/examples/SCAFFOLD.md b/examples/SCAFFOLD.md
index f0087e6c945e0b451146eb13f72d3e431fdf5ea6..5bde382b7f3c2841ce4addd8da9247d6c87122dd
--- a/examples/SCAFFOLD.md
+++ b/examples/SCAFFOLD.md
@@ -1,30 +1,36 @@
 # `examples/` — canonical minimal manifests
 
-Root `*.yaml` files are one PAM resource type each, minimal shape, valid against
-`keeper_sdk/core/schemas/pam-environment.v1.schema.json`.
+Root `*.yaml` files are validate-clean examples for the packaged declarative
+families that have CLI validation paths today: `pam-environment.v1`,
+`keeper-vault.v1`, and `keeper-vault-sharing.v1`.
 
-`examples/scaffold_only/*.yaml` are **non-PAM** packaged-schema samples
-(`keeper-vault.v1`, `keeper-vault-sharing.v1`, …). **`dsk validate`** runs on them
-in CI in the same loop as root `examples/*.yaml` (`.github/workflows/ci.yml`
-`examples` job). The **`examples` job’s mock `plan` step** only iterates
-`examples/*.yaml` (not `scaffold_only/`); vault **`plan` / `diff` / `apply`** for
-`keeper-vault.v1` is exercised in **pytest** (`tests/test_vault_mock_provider.py`,
-`tests/test_cli.py`, …) via `load_declarative_manifest` + `MockProvider` /
-`CommanderCliProvider` fakes — not omitted from coverage.
+`examples/scaffold_only/*.yaml` remain tiny packaged-family starter documents.
+They are kept for backwards-compatible references and schema smoke coverage.
+Root examples are validated by the dedicated `examples-validate` CI job with
+`python -m keeper_sdk.cli validate`; the existing `examples` CI job also validates
+root + scaffold-only manifests and runs mock plans for root examples.
 
 ## Files
 
 | File | Resource type | Notes |
 |---|---|---|
 | `pamMachine.yaml` | `pamMachine` | Reference shape — copy this for new examples. |
+| `pam-machine-multi.yaml` | `pamMachine` | Three machines, mixed string/integer ports, and RBI connection options. |
 | `pamDatabase.yaml` | `pamDatabase` | Includes `database_type` to satisfy verifier. |
+| `pam-database-cluster.yaml` | `pamDatabase` | Primary + replica records sharing one PAM configuration. |
 | `pamDirectory.yaml` | `pamDirectory` | Includes directory-specific binding fields. |
 | `pamRemoteBrowser.yaml` | `pamRemoteBrowser` | Connection settings only — RBI tri-state and audio keys remain preview-gated. |
+| `sharing.example.yaml` | `keeper-vault-sharing.v1` | Minimal folder, shared-folder, record-share, and folder-grantee rows. |
+| `sharing-folders-shared.yaml` | `keeper-vault-sharing.v1` | Three folders plus two shared folders. |
+| `sharing-grantees.yaml` | `keeper-vault-sharing.v1` | User, team, record, and default share-folder rows. |
+| `vault-records.yaml` | `keeper-vault.v1` | Five L1-compatible login records exercising login, payment-card, database, server, and custom field payloads. |
+| `vault-record-types.yaml` | `keeper-vault.v1` | Custom `record_types[]` declarations. |
+| `vault-attachments.yaml` | `keeper-vault.v1` | `attachments[]` declarations attached to a login record. |
 
 ### `scaffold_only/` (packaged families; CI validate)
 
 | File | `schema:` | Notes |
-|------|-----------|-------|
+|---|---|---|
 | `vaultMinimal.yaml` | `keeper-vault.v1` | Empty `records` — offline `dsk validate` + `dsk validate --json` (`vault_offline`). |
 | `vaultOneLogin.yaml` | `keeper-vault.v1` | Single **`login`** row for L1 lab / V8 prep; edit `uid_ref` / titles for your folder. |
 | `vaultSharingMinimal.yaml` | `keeper-vault-sharing.v1` | Empty sharing blocks (defaults). |
@@ -34,6 +40,8 @@
 | Change | File | Sibling to copy |
 |---|---|---|
 | New example resource type | `<name>.yaml` + add to CI examples job + `tests/test_smoke_scenarios.py` shape | `pamMachine.yaml` |
+| New vault example | `<name>.yaml` + `tests/test_examples_validate.py` covers schema validation | `vault-records.yaml` |
+| New sharing example | `<name>.yaml` + `tests/test_examples_validate.py` covers schema validation | `sharing.example.yaml` |
 | New scaffold-only family sample | `examples/scaffold_only/<name>.yaml` + CI validate loop already glob-matches `scaffold_only/*.yaml` | `vaultMinimal.yaml` |
 
 ## Hard rules
