+
+record_types:
+  - uid_ref: rt.service-account
+    scope: enterprise
+    record_type_id: 3001001
+    content:
+      $id: serviceAccount
+      categories: ["login"]
+      description: "Service account credential"
+      fields:
+        - $ref: login
+          label: Username
+          required: true
+        - $ref: password
+          label: Password
+          required: true
+        - $ref: host
+          label: Endpoint
+
+  - uid_ref: rt.break-glass-admin
+    scope: enterprise
+    record_type_id: 3001002
+    content:
+      $id: breakGlassAdmin
+      categories: ["login", "admin"]
