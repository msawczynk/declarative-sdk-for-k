+schema: keeper-vault-sharing.v1
+
+# Folder topology with three private folders and two shared folders.
+#
+# Run:
+#   dsk validate examples/sharing-folders-shared.yaml
+#   dsk plan     examples/sharing-folders-shared.yaml --provider mock --json
+
+folders:
+  - uid_ref: folder.engineering
+    path: /Engineering
+    color: blue
+
+  - uid_ref: folder.engineering.platform
+    path: /Engineering/Platform
+    parent_folder_uid_ref: keeper-vault-sharing:folders:folder.engineering
+    color: green
+
+  - uid_ref: folder.operations
+    path: /Operations
+    color: orange
+
+shared_folders:
+  - uid_ref: sf.engineering
+    path: /Shared/Engineering
+    defaults:
+      manage_users: false
+      manage_records: true
+      can_edit: true
+      can_share: false
+
+  - uid_ref: sf.operations
+    path: /Shared/Operations
+    defaults:
+      manage_users: true
+      manage_records: true
+      can_edit: false
+      can_share: false
diff --git a/examples/sharing-grantees.yaml b/examples/sharing-grantees.yaml
new file mode 100644
index 0000000000000000000000000000000000000000..b0f7b91a360712644772a753c008789e263c7f14
--- /dev/null
+++ b/examples/sharing-grantees.yaml
@@ -0,0 +1,69 @@
+schema: keeper-vault-sharing.v1
+
+# Shared-folder grants demonstrating user, team, record, and default share rows.
+#
+# Run:
+#   dsk validate examples/sharing-grantees.yaml
+#   dsk plan     examples/sharing-grantees.yaml --provider mock --json
+
+shared_folders:
+  - uid_ref: sf.platform
+    path: /Shared/Platform
+    defaults:
+      manage_users: false
+      manage_records: true
+      can_edit: true
+      can_share: false
+
+share_records:
+  - uid_ref: share.record.admin.alice
+    record_uid_ref: keeper-vault:records:rec.login.web-admin
+    user_email: alice@example.com
+    permissions:
+      can_edit: false
+      can_share: false
+
+share_folders:
+  - kind: grantee
+    uid_ref: sf.platform.user.alice
+    shared_folder_uid_ref: keeper-vault-sharing:shared_folders:sf.platform
+    grantee:
+      kind: user
+      user_email: alice@example.com
+    permissions:
+      manage_records: true
+      manage_users: false
+
+  - kind: grantee
+    uid_ref: sf.platform.team.ops
+    shared_folder_uid_ref: keeper-vault-sharing:shared_folders:sf.platform
+    grantee:
+      kind: team
+      team_uid_ref: keeper-enterprise:teams:team.ops
+    permissions:
+      manage_records: true
+      manage_users: true
+
+  - kind: record
+    uid_ref: sf.platform.record.web-admin
+    shared_folder_uid_ref: keeper-vault-sharing:shared_folders:sf.platform
+    record_uid_ref: keeper-vault:records:rec.login.web-admin
+    permissions:
+      can_edit: true
+      can_share: false
+
+  - kind: default
+    uid_ref: sf.platform.default.grantee
+    shared_folder_uid_ref: keeper-vault-sharing:shared_folders:sf.platform
+    target: grantee
+    permissions:
+      manage_records: true
+      manage_users: false
+
+  - kind: default
+    uid_ref: sf.platform.default.record
+    shared_folder_uid_ref: keeper-vault-sharing:shared_folders:sf.platform
+    target: record
+    permissions:
+      can_edit: true
+      can_share: false
