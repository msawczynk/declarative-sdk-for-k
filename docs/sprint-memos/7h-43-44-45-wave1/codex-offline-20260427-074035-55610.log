    ),
    "keeper-ksm.v1": "keeper-ksm/keeper-ksm.v1.schema.json",
    "keeper-pam-extended.v1": "keeper-pam-extended/keeper-pam-extended.v1.schema.json",
    "keeper-security-posture.v1": (
