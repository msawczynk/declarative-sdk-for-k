+    shared_folder: resources
+    host: 10.16.10.12
+    port: "5900"
+    ssl_verification: false
+    operating_system: macOS
+    pam_settings:
+      options:
+        connections: "on"
+        tunneling: "on"
+      allow_supply_host: true
+      connection:
+        protocol: vnc
+        port: "5900"
+        allow_supply_user: true
