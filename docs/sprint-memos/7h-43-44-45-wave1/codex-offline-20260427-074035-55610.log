+      - type: password
+        label: Password
+        value: ["example-db-password"]
+      - type: host
+        label: Host
+        value:
+          - hostName: db.example.invalid
+            port: 5432
+    custom:
+      - type: text
+        label: Database
+        value: ["orders"]
+
+  - uid_ref: rec.server.credentials
