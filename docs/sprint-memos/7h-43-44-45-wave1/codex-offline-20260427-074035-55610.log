+    database_id: example-orders-replica
+    host: db-replica.example.invalid
+    port: "5433"
+    use_ssl: true
+    pam_settings:
+      options:
+        connections: "on"
+        tunneling: "on"
+      connection:
+        protocol: postgresql
+        port: "5433"
+        default_database: orders
