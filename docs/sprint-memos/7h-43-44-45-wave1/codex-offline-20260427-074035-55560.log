+def _allow_provider(monkeypatch: pytest.MonkeyPatch) -> None:
+    monkeypatch.setattr(
+        "keeper_sdk.providers.commander_cli.shutil.which",
+        lambda _bin: "/usr/bin/keeper",
+    )
+    monkeypatch.delenv("KEEPER_DECLARATIVE_FOLDER", raising=False)
