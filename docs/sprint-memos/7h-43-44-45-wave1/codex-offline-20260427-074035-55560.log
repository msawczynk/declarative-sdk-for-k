    37	    def creates(self) -> list[Change]:
    38	        return [c for c in self.changes if c.kind is ChangeKind.CREATE]
    39	
    40	    @property
    41	    def updates(self) -> list[Change]:
    42	        return [c for c in self.changes if c.kind is ChangeKind.UPDATE]
    43	
    44	    @property
    45	    def deletes(self) -> list[Change]:
    46	        return [c for c in self.changes if c.kind is ChangeKind.DELETE]
    47	
    48	    @property
    49	    def conflicts(self) -> list[Change]:
    50	        return [c for c in self.changes if c.kind is ChangeKind.CONFLICT]
    51	
    52	    @property
    53	    def noops(self) -> list[Change]:
    54	        return [c for c in self.changes if c.kind is ChangeKind.NOOP]
    55	
    56	    @property
    57	    def is_clean(self) -> bool:
    58	        return not (self.creates or self.updates or self.deletes or self.conflicts)
    59	
    60	    def ordered(self) -> list[Change]:
    61	        """Return changes in a safe execution order."""
    62	        index = {uid_ref: idx for idx, uid_ref in enumerate(self.order)}
    63	
    64	        def key_forward(change: Change) -> tuple[int, int, str]:
    65	            rank = index.get(change.uid_ref or "", 10_000)
    66	            return (0, rank, change.title)
    67	
    68	        def key_reverse(change: Change) -> tuple[int, int, str]:
    69	            rank = index.get(change.uid_ref or "", 10_000)
