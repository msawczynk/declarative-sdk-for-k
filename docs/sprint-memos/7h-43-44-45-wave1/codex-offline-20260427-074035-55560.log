   111	
   112	def compute_diff(
   113	    manifest: Manifest,
   114	    live_records: list[LiveRecord],
   115	    *,
   116	    manifest_name: str | None = None,
   117	    allow_delete: bool = False,
   118	    adopt: bool = False,
   119	) -> list[Change]:
   120	    """Classify desired (manifest) vs observed (live) state.
   121	
   122	    Matching rules:
   123	      1. Prefer ``LiveRecord.marker.uid_ref == desired.uid_ref`` when present.
   124	      2. Otherwise match by ``(resource_type, title)``.
   125	      3. Records marked by a *different* manager are flagged as CONFLICT
   126	         and never touched — the SDK owns only what it wrote.
   127	
   128	    The function is deliberately a thin orchestrator: the three hard
   129	    sub-problems (duplicate detection, desired-vs-live matching, orphan
   130	    classification) live in private helpers so each can be read + tested
   131	    in isolation.
   132	    """
   133	    manifest_name = manifest_name or manifest.name
   134	    _raise_live_record_collisions(live_records)
   135	
   136	    by_uid_ref, by_title = _index_live(live_records)
   137	
   138	    changes: list[Change] = []
   139	    matched: set[str] = set()
   140	
   141	    for uid_ref, resource_type, title, payload in _desired_objects(manifest):
   142	        live = by_uid_ref.get(uid_ref) or by_title.get((resource_type, title))
   143	        change = _classify_desired(
   144	            uid_ref=uid_ref,
   145	            resource_type=resource_type,
   146	            title=title,
   147	            payload=payload,
   148	            live=live,
   149	            by_title=by_title,
   150	            adopt=adopt,
   151	        )
   152	        changes.append(change)
   153	        if change.kind in (ChangeKind.UPDATE, ChangeKind.NOOP) and live is not None:
   154	            matched.add(live.keeper_uid)
   155	
   156	    changes.extend(
   157	        _classify_orphans(
   158	            live_records,
   159	            matched=matched,
   160	            manifest_name=manifest_name,
   161	            allow_delete=allow_delete,
   162	        )
   163	    )
   164	
   165	    return changes
   166	
   167	
   168	def _index_live(
   169	    live_records: list[LiveRecord],
   170	) -> tuple[dict[str, LiveRecord], dict[tuple[str, str], LiveRecord]]:
   171	    """Return two lookup dicts over live records: by marker uid_ref, by (type, title)."""
   172	    by_uid_ref: dict[str, LiveRecord] = {}
