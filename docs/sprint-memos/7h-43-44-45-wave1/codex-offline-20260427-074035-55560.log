   578	def test_run_cmd_falls_back_to_subprocess_for_ls_get_without_login_config(
   579	    monkeypatch: pytest.MonkeyPatch,
   580	) -> None:
   581	    """No helper + no env creds + no cached params ⇒ ls/get use subprocess.
   582	
   583	    Plain installs (no ``KEEPER_SDK_LOGIN_HELPER``, no env creds, no
   584	    apply-time login yet) must keep working through subprocess so we don't
   585	    regress users who only have ``~/.keeper/commander-config.json``.
   586	    """
   587	    monkeypatch.setattr(
   588	        "keeper_sdk.providers.commander_cli.shutil.which", lambda _bin: "/usr/bin/keeper"
   589	    )
   590	    monkeypatch.delenv("KEEPER_SDK_LOGIN_HELPER", raising=False)
   591	    monkeypatch.delenv("KEEPER_EMAIL", raising=False)
   592	    monkeypatch.delenv("KEEPER_PASSWORD", raising=False)
   593	    monkeypatch.delenv("KEEPER_TOTP_SECRET", raising=False)
   594	
   595	    seen_argv: list[list[str]] = []
   596	
   597	    def fake_run(*args: object, **_kwargs: object) -> subprocess.CompletedProcess[str]:
   598	        argv = list(args[0]) if args else []
   599	        seen_argv.append(argv)
   600	        return subprocess.CompletedProcess(argv, 0, stdout="[]", stderr="")
   601	
   602	    monkeypatch.setattr("keeper_sdk.providers.commander_cli.subprocess.run", fake_run)
   603	
   604	    provider = CommanderCliProvider(folder_uid="folder-uid")
   605	    assert provider._run_cmd(["ls", "FOLDER_UID", "--format", "json"]) == "[]"
   606	    assert provider._run_cmd(["get", "REC1", "--format", "json"]) == "[]"
   607	    assert any(argv[-4:] == ["ls", "FOLDER_UID", "--format", "json"] for argv in seen_argv)
   608	    assert any(argv[-4:] == ["get", "REC1", "--format", "json"] for argv in seen_argv)
   609	
