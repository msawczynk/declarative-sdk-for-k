+    )
+
+    outcomes = provider.apply_plan(plan)
+
+    assert [(row.action, row.uid_ref, row.keeper_uid) for row in outcomes] == [
+        ("conflict", "pam.conflict", "UIDC"),
+        ("noop", "pam.noop", "UIDN"),
