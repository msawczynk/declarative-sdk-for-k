+        Change(
+            kind=ChangeKind.CONFLICT,
+            uid_ref="pam.conflict",
+            resource_type="pamDatabase",
+            title="db-conflict",
+            keeper_uid="UIDC",
+            reason="owned elsewhere",
+        ),
+        Change(
+            kind=ChangeKind.NOOP,
+            uid_ref="pam.noop",
+            resource_type="pamDatabase",
+            title="db-noop",
+            keeper_uid="UIDN",
