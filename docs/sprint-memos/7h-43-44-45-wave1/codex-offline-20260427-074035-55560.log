    16	class ChangeKind(StrEnum):
    17	    """Classification of a single planned change.
    18	
    19	    * ``CREATE`` / ``ADD`` — manifest describes a resource that does not exist in
    20	      the vault yet.
    21	    * ``ADD`` — backwards-compatible alias for ``CREATE`` used by newer
    22	      sibling-block diff helpers.
    23	    * ``UPDATE`` — manifest and vault both carry the resource but their
    24	      fields drift. Only raised when drift is detected on declarative
    25	      (manifest-owned) fields — SDK-internal placement metadata is
    26	      ignored via :data:`_DIFF_IGNORED_FIELDS`.
    27	    * ``DELETE`` — vault carries a record with an ownership marker whose
    28	      ``uid_ref`` is absent from the manifest. Requires
    29	      ``allow_delete=True`` on ``compute_diff``.
    30	    * ``NOOP`` — manifest and vault agree; no action required.
    31	    * ``SKIP`` — a non-actionable observed object is intentionally left
    32	      untouched, usually because it is unmanaged by this SDK or because
    33	      a managed live object is missing from the manifest without
    34	      ``allow_delete``.
    35	    * ``CONFLICT`` — a situation the planner cannot resolve automatically
    36	      (name collision, ambiguous marker, incompatible type). Operator
    37	      must resolve before re-running.
    38	    """
    39	
    40	    CREATE = "create"
    41	    ADD = "create"
    42	    UPDATE = "update"
    43	    DELETE = "delete"
    44	    NOOP = "noop"
    45	    SKIP = "skip"
    46	    CONFLICT = "conflict"
    47	
    48	
    49	@dataclass
    50	class Change:
    51	    """One row of a :class:`Plan`.
    52	
    53	    Attributes:
    54	        kind: Classification — see :class:`ChangeKind`.
    55	        uid_ref: Manifest handle. ``None`` only for deletes on records
    56	            that never had a declarative owner (should be rare).
    57	        resource_type: Declarative type (``pamMachine``, ``gateway``, …).
    58	        title: Human-facing identifier used by renderers and by
    59	            Commander ``pam project import`` to match records.
    60	        keeper_uid: Vault UID of the matched live record; ``None`` on
    61	            pure creates.
    62	        before / after: Normalised field dicts for diff rendering.
    63	        reason: Optional human-readable explanation (used for NOOP /
    64	            CONFLICT rows).
    65	        manifest_name: Optional manifest identifier for synthetic rows that
    66	            do not map to a live record marker.
    67	    """
    68	
    69	    kind: ChangeKind
