    92	def _desired_objects(manifest: Manifest) -> list[tuple[str, str, str, dict[str, Any]]]:
    93	    """Yield (uid_ref, resource_type, title, payload) for every managed object."""
    94	    out: list[tuple[str, str, str, dict[str, Any]]] = []
    95	    data = manifest.model_dump(mode="python", exclude_none=True)
    96	
    97	    for gateway in data.get("gateways") or []:
    98	        if gateway.get("mode") == "create":
    99	            out.append((gateway["uid_ref"], "gateway", gateway.get("name", ""), gateway))
   100	    for cfg in data.get("pam_configurations") or []:
   101	        title = cfg.get("title") or cfg.get("uid_ref")
   102	        out.append((cfg["uid_ref"], "pam_configuration", title, cfg))
   103	    for res in data.get("resources") or []:
   104	        out.append((res["uid_ref"], res["type"], res.get("title", ""), res))
   105	        for user in res.get("users") or []:
   106	            out.append((user.get("uid_ref") or "", user["type"], user.get("title", ""), user))
   107	    for user in data.get("users") or []:
   108	        out.append((user.get("uid_ref") or "", user["type"], user.get("title", ""), user))
   109	    return out
