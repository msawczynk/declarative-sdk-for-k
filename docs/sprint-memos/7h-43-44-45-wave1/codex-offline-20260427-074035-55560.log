+        Change(
+            kind=ChangeKind.DELETE,
+            uid_ref="pam.db",
+            resource_type="pamDatabase",
+            title="db",
+            keeper_uid="UID1",
+        )
+    )
+
+    with pytest.raises(CapabilityError, match="rm denied"):
+        provider.apply_plan(plan)
+
