+def test_check_tenant_bindings_reports_config_binding_issues(
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    """covers L475-L496 (config missing, shared-folder missing, gateway mismatch)."""
+    provider = _provider(
