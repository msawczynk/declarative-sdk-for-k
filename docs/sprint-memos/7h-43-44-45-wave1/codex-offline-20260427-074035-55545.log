+def test_manifest_source_is_vault_uses_model_dump() -> None:
+    """covers L165 (typed manifest source is read through model_dump)."""
+
+    class VaultSource:
+        def model_dump(
+            self, *, mode: str, exclude_none: bool, by_alias: bool
+        ) -> dict[str, str]:
