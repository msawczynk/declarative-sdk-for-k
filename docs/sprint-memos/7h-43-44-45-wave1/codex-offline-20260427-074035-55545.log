+        lambda _manifest: {"project": "customer-prod", "pam_data": {"resources": []}},
+    )
+    monkeypatch.setattr(provider, "_run_cmd", lambda _args: "")
+    monkeypatch.setattr(provider, "_resolve_project_resources_folder", lambda _name: "folder-uid")
