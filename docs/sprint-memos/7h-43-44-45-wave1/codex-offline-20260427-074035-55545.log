+def test_enrich_pam_remote_browser_dag_options_branches(
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    """covers L318-L355 (TunnelDAG import, cache, skip, and merge paths)."""
+    provider = _provider(monkeypatch)
