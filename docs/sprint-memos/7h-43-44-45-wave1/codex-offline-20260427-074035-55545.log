+            "pam_data": {
+                "resources": [
+                    {
+                        "title": "db-prod",
+                        "users": [
+                            {
+                                "username": "db-user",
+                                "folder_path": "customer-prod - Users",
+                            }
+                        ],
+                        "folder_path": "customer-prod - Resources",
+                    }
+                ],
+                "users": [{"username": "top-user", "folder_path": "customer-prod - Users"}],
+            }
+        }
+    ]
+    assert outcomes[0].details == {"dry_run": True}
