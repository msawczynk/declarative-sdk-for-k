+
+def _create_plan(*, uid_ref: str = "res.db", title: str = "db-prod") -> Plan:
+    return Plan(
+        manifest_name="customer-prod",
+        changes=[
+            Change(
+                kind=ChangeKind.CREATE,
+                uid_ref=uid_ref,
+                resource_type="pamDatabase",
+                title=title,
+                after={"title": title},
+            )
+        ],
+        order=[uid_ref],
+    )
