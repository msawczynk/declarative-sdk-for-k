+    )
+
+    provider._manifest_source = {"resources": [{"uid_ref": "res.browser"}]}
+    assert (
+        provider._resolve_pam_configuration_keeper_uid(
+            LiveRecord(
+                keeper_uid="RBI_UID",
+                title="Browser",
+                resource_type="pamRemoteBrowser",
+                marker={"uid_ref": "res.browser"},
