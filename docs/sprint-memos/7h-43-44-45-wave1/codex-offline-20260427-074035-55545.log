+                "gateway_uid": "GW_EXPECTED",
+                "shared_folder_uid": "",
+            },
+            {
+                "config_name": "Gateway Mismatch",
+                "config_uid": "CFG_MISMATCH",
+                "gateway_uid": "GW_ACTUAL",
+                "shared_folder_uid": "SF_UID",
