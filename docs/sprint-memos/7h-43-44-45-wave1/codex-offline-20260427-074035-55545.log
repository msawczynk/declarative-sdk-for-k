+    assert issues[2] == (
+        "pam_configuration 'Gateway Mismatch' declares gateway_uid_ref='gw.expected' "
+        "(uid=GW_EXPECTED) but tenant pairs it with gateway uid 'GW_ACTUAL'"
+    )
