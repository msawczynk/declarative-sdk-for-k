name: CI

on:
  push:
    branches: [main]
  pull_request:
    # Trigger on PRs targeting `main` AND PRs targeting any `cursor/**`
    # or `codex/**` branch so stacked PRs (child PRs whose base is a
    # parent PR's branch instead of `main`) receive CI signal before
    # they're rebased onto `main`. Lesson `[pr-merge][stacked-base-retarget]`
    # 2026-04-26 traced a CI-blind merge to this gap.
    branches: [main, 'cursor/**', 'codex/**']

permissions:
  contents: read

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

jobs:
  lint:
    name: lint (ruff)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - run: pip install ruff
      - run: ruff check .
      - run: ruff format --check .

  typecheck:
    name: typecheck (mypy)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - run: pip install -e ".[dev]"
      - run: mypy keeper_sdk

  test:
    name: test (py${{ matrix.python }})
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        python: ["3.11", "3.12", "3.13"]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.python }}
      - run: pip install -e ".[dev]"
      # Coverage ratchet: baseline at 86% (commit 2026-04-26 post-Sprint-7h-5
      # cov slices for redact/schema/normalize landing at 100%, 315 tests).
      # Floor raised 84 -> 85 in Sprint 7h-41 V6c after V6b sibling-diff
      # landing lifted exact cov to 85.47% (663+1 tests, 5583 stmts, 811
      # missing). WORKTREES.md §8 closes. Raise the floor when adding
      # net-new tested surface; never lower it without rationale in JOURNAL.md.
      - run: pytest -q --cov=keeper_sdk --cov-report=term-missing --cov-fail-under=85
        env:
          # Offline-only; live-smoke against a real tenant runs via
          # scripts/smoke/smoke.py in a separate, credential-bearing
          # workflow (not in public CI).
          DSK_CI: "1"

  examples:
    name: examples (validate + mock-plan)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - run: pip install -e ".[dev]"
      - name: Validate every example manifest (offline schema gate)
        run: |
          set -euo pipefail
          shopt -s nullglob
          for f in examples/*.yaml examples/scaffold_only/*.yaml; do
            echo "::group::validate $f"
            dsk validate "$f"
            echo "::endgroup::"
          done
      - name: Plan every example against mock provider (no CONFLICT rows)
        run: |
          set -e
          for f in examples/*.yaml; do
            echo "::group::plan $f"
            # plan exits 2 on "changes pending" (intentional, see
            # docs/VALIDATION_STAGES.md) — capture instead of failing.
            out=$(dsk --provider mock plan "$f" --json) || true
            echo "$out" | python -c 'import json,sys,os; d=json.loads(sys.stdin.read()); s=d["summary"]; print(s); sys.exit(0 if s["conflict"]==0 else 1)'
            echo "::endgroup::"
          done

  schema-validate:
    name: schema-validate (RFC 8259)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      # Plain stdlib json.tool — RFC 8259 strict (no trailing commas, no
      # comments). Sprint 7h-15 LESSON [worker][format-on-rebase-jsonc-trap]:
      # ruff format over the schemas dir introduces JSONC trailing commas
      # that pytest tolerates but external schema validators reject.
      - name: Validate every schema file is RFC 8259-compliant JSON
        run: |
          set -e
          fail=0
          for f in $(find keeper_sdk/core/schemas -name '*.json' -type f); do
            if ! python -m json.tool < "$f" > /dev/null 2>&1; then
              echo "::error file=$f::not RFC 8259-compliant JSON (trailing comma? comment? unquoted key?)"
              fail=1
            fi
          done
          if [ -d docs/live-proof ]; then
            for f in $(find docs/live-proof -name '*.json' -type f); do
              if ! python -m json.tool < "$f" > /dev/null 2>&1; then
                echo "::error file=$f::not RFC 8259-compliant JSON (trailing comma? comment? unquoted key?)"
                fail=1
              fi
            done
          fi
          [ "$fail" -eq 0 ] || exit 1
          echo "All schema + docs/live-proof JSON files clean."

  drift-check:
    name: drift-check (upstream capability mirror)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Read Commander pin
        id: pin
        run: echo "sha=$(tr -d '[:space:]' < .commander-pin)" >> "$GITHUB_OUTPUT"
      - name: Clone Commander at pinned SHA
        uses: actions/checkout@v4
        with:
          repository: Keeper-Security/Commander
          ref: ${{ steps.pin.outputs.sha }}
          path: Commander
          # fetch-depth: 0 is required when `ref` is a bare commit SHA
          # (depth=1 only works for branch/tag tips).
          fetch-depth: 0
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - name: Install Commander runtime deps (so argparse introspection works)
        run: pip install -r Commander/requirements.txt
      - name: Ensure generated matrix matches upstream
        run: |
          python scripts/sync_upstream.py --check --commander ./Commander
        # Failure mode: either the pin moved and docs/CAPABILITY_MATRIX.md
        # + docs/capability-snapshot.json need regenerating (run the script
        # without --check locally and commit), or someone hand-edited one
        # of those files (they're generated; don't).

  build:
    name: build (sdist + wheel)
    runs-on: ubuntu-latest
    needs: [lint, typecheck, test, drift-check, examples, schema-validate]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - run: pip install build twine
      - run: python -m build
      - run: twine check dist/*
      - uses: actions/upload-artifact@v4
        with:
          name: dist
          path: dist/*

