 succeeded in 0ms:
#!/usr/bin/env bash
# ksm_login_preflight.sh — verify Keeper login preconditions BEFORE attempting Commander login.
#
# Why: past sessions repeatedly hung on interactive Commander login or TOTP prompts even though
# LESSONS.md documents a working KSM-backed flow. This script is the gate: if it exits 0, the
# environment is ready to source creds via `ksm_creds.sh`; if it exits non-zero, STOP — do not
# attempt interactive login (lesson `[keeper-totp]` 2026-04-24, `[orchestration]` 2026-04-24).
#
# Output discipline: prints OK/MISSING <thing> ONLY. Never echoes env values, secrets, TOTP, or
# config contents. Safe to run inside an agent transcript.
#
# Canonical location: ~/.cursor-daybook-sync/scripts/ — synced via the daybook git mirror so
# every Cursor workspace sees the same script.
#
# Usage:
#   bash ~/.cursor-daybook-sync/scripts/ksm_login_preflight.sh
#   KSM_RECORD_UID=<uid> KSM_CONFIG=<path> bash ~/.cursor-daybook-sync/scripts/ksm_login_preflight.sh
#
# Exit codes:
#   0 — ready (caller may source creds and run live smoke)
#   1 — missing helper script
#   2 — missing KSM config / record / connectivity
#   3 — caller-supplied env override is incomplete (some KEEPER_* set but not all)

set -u

KSM_HELPER="${KSM_HELPER:-$HOME/.cursor-daybook-sync/scripts/ksm_creds.sh}"
KSM_LIB="${KSM_LIB:-$HOME/.cursor-daybook-sync/scripts/ksm_lib.py}"
KSM_RECORD_UID="${KSM_RECORD_UID:-MyiZN4cw-wtEIpY1jHlhLw}"
# Default lab KSM config — the lab admin record (UID above) is only visible to this app config,
# not the caravan/personal one (per JOURNAL handoff). Override KSM_CONFIG if running outside lab.
DEFAULT_LAB_CONFIG="/Users/martin/Downloads/Cursor tests/keeper-vault-rbi-pam-testenv/ksm-config.json"
KSM_CONFIG="${KSM_CONFIG:-$DEFAULT_LAB_CONFIG}"

fail=0

# Helper + lib must exist.
if [ ! -f "$KSM_HELPER" ]; then
  echo "MISSING ksm_creds.sh ($KSM_HELPER)"
  fail=1
fi
if [ ! -f "$KSM_LIB" ]; then
  echo "MISSING ksm_lib.py ($KSM_LIB)"
  fail=1
fi

# If caller has already sourced env vars, treat as ready (don't echo values).
have_email=0; have_pass=0; have_totp=0
[ -n "${KEEPER_EMAIL:-}" ] && have_email=1
[ -n "${KEEPER_PASSWORD:-}" ] && have_pass=1
[ -n "${KEEPER_TOTP_SECRET:-}" ] && have_totp=1
total_env=$((have_email + have_pass + have_totp))

if [ "$total_env" -eq 3 ] && [ "$fail" -eq 0 ]; then
  echo "OK env=caller-sourced helper=present"
  exit 0
elif [ "$total_env" -gt 0 ] && [ "$total_env" -lt 3 ]; then
  echo "MISSING partial-env: email=$have_email pass=$have_pass totp=$have_totp (caller set some but not all)"
  exit 3
fi

# Need a record UID for the helper to resolve.
if [ -z "${KSM_RECORD_UID}" ]; then
  echo "MISSING KSM_RECORD_UID (default lab UID is MyiZN4cw-wtEIpY1jHlhLw)"
  fail=2
fi

# Probe KSM lookup without printing the result.
if [ "$fail" -eq 0 ]; then
  probe_args=(export-keeper --uid "$KSM_RECORD_UID")
  if [ -n "${KSM_CONFIG:-}" ] && [ -f "$KSM_CONFIG" ]; then
    probe_args+=(--config "$KSM_CONFIG")
  fi
  if ! python3 "$KSM_LIB" "${probe_args[@]}" >/dev/null 2>&1; then
    echo "MISSING ksm-lookup: record not resolvable with config=${KSM_CONFIG:-<unset>}"
    echo "  hint: lab admin record needs the lab ksm-config (default $DEFAULT_LAB_CONFIG); set KSM_CONFIG to override"
    fail=2
  fi
fi

if [ "$fail" -eq 0 ]; then
  echo "OK ksm helper=present record=resolvable config=$(basename "$KSM_CONFIG")"
  exit 0
fi

exit "$fail"

