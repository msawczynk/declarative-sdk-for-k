run_id = os.environ["RUN_ID"]
source_config = os.environ["KEEPER_SDK_KSM_CONFIG"]
admin_uid = os.environ["KEEPER_SDK_KSM_CREDS_RECORD_UID"]
config_out = Path("/tmp") / f"dsk-ksm-l1-{commit_short}-{run_id}-ksm-config.json"
app_name = f"dsk-ksm-l1-{commit_short}"
bus_title = f"dsk-ksm-l1-bus-{commit_short}"

started_at = datetime.now(UTC).isoformat(timespec="seconds").replace("+00:00", "Z")
events: list[dict[str, Any]] = []


def fp(value: str, prefix: str = "sha256") -> str:
    return f"<{prefix}:{hashlib.sha256(value.encode('"'utf-8')).hexdigest()[:8]}>\"


def value_hash(value: str) -> str:
    return hashlib.sha256(value.encode(\"utf-8\")).hexdigest()[:8]


def elapsed_ms(t0: float) -> int:
    return int((time.monotonic() - t0) * 1000)


def event(name: str, t0: float | None = None, **details: Any) -> None:
    row: dict[str, Any] = {\"event\": name, \"result\": \"ok\"}
    if t0 is not None:
        row[\"elapsed_ms\"] = elapsed_ms(t0)
    row.update(details)
    events.append(row)


def field_shape(desc: dict[str, Any], block: str) -> list[dict[str, Any]]:
    return [
        {\"type\": item.get(\"type\"), \"label\": item.get(\"label\") or \"\", \"has_value\": bool(item.get(\"has_value\"))}
        for item in desc.get(block, [])
    ]

try:
    t0 = time.monotonic()
    helper = KsmLoginHelper()
    creds = helper.load_keeper_creds()
    source_store = KsmSecretStore(config_path=source_config)
    source_desc = source_store.describe(admin_uid)
    event(
        \"ksm_login_helper_load\",
        t0,
        record_uid_hash=fp(admin_uid, \"uid\"),
        source_config_basename=Path(source_config).name,
        fields=field_shape(source_desc, \"fields\"),
    )

    t0 = time.monotonic()
    params = helper.keeper_login(**creds)
    event(
        \"commander_login\",
        t0,
        server=getattr(params, \"server\", \"\") or os.environ.get(\"KEEPER_SERVER\", \"\"),
        session=\"established\",
    )

    t0 = time.monotonic()
    result = bootstrap_ksm_application(
        params=params,
        app_name=app_name,
        admin_record_uid=admin_uid,
        config_out=config_out,
        first_access_minutes=10,
        unlock_ip=False,
        create_bus_directory=True,
        bus_directory_title=bus_title,
        overwrite=True,
    )
    if not result.bus_directory_uid:
        raise RuntimeError(\"bootstrap did not return a bus directory uid\")
    event(
