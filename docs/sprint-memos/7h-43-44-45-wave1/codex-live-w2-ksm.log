#!/usr/bin/env bash
# Source Keeper login credentials from a KSM record into the current shell.
#
# Usage:
#   . ~/.cursor-daybook-sync/scripts/ksm_creds.sh <RECORD_UID> [<KSM_CONFIG_PATH>]
#
# After sourcing, $KEEPER_EMAIL / $KEEPER_PASSWORD / $KEEPER_TOTP_SECRET are
# set in the parent shell. The values are never echoed by this script.
#
# Convention: the KSM record carries fields ``login``, ``password``, and
# ``oneTimeCode`` (otpauth:// URI). Same shape as deploy_watcher uses.
#
# Environment overrides (read once at source-time):
#   $KSM_CREDS_RECORD_UID  default UID if positional $1 omitted
#   $KSM_CONFIG            default config path if positional $2 omitted

# Precedence: env var > positional. Sourcing in zsh inherits the parent
# shell's $1/$2, which may carry stale values from earlier function calls;
# preferring env vars makes the script safe under both bash and zsh source.
_ksm_record_uid="${KSM_CREDS_RECORD_UID:-${1:-}}"
_ksm_config_path="${KSM_CONFIG:-${2:-}}"

if [[ -z "$_ksm_record_uid" ]]; then
  echo "ksm_creds: missing record UID (pass as \$1 or set KSM_CREDS_RECORD_UID)" >&2
  return 2 2>/dev/null || exit 2
fi

# `python3 -c "import ksm_lib"` requires the script dir on sys.path; ksm_lib
# auto-adds itself when imported by absolute path, so use that form.
_ksm_lib="$HOME/.cursor-daybook-sync/scripts/ksm_lib.py"
if [[ ! -f "$_ksm_lib" ]]; then
  echo "ksm_creds: ksm_lib.py not found at $_ksm_lib" >&2
  return 2 2>/dev/null || exit 2
fi

_ksm_export_args=( "export-keeper" "--uid" "$_ksm_record_uid" )
if [[ -n "$_ksm_config_path" ]]; then
  _ksm_export_args+=( "--config" "$_ksm_config_path" )
fi

_ksm_export_lines="$(python3 "$_ksm_lib" "${_ksm_export_args[@]}")" || {
  echo "ksm_creds: KSM lookup failed for ${_ksm_record_uid:0:6}..." >&2
  unset _ksm_record_uid _ksm_config_path _ksm_lib _ksm_export_args _ksm_export_lines
  return 3 2>/dev/null || exit 3
}

eval "$_ksm_export_lines"
unset _ksm_record_uid _ksm_config_path _ksm_lib _ksm_export_args _ksm_export_lines

