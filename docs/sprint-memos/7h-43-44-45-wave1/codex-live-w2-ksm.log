"""KSM helpers for cross-agent credential retrieval (and, later, message bus).

Operator-side library, NOT part of the SDK delivery surface. Agents source
credentials from a Keeper Secrets Manager record instead of injecting env
vars or reading local files. Long-term, the same module can host topic
records for inter-agent state exchange.

Config discovery order (first usable wins, unless the caller passes
``config_path`` explicitly):

1. ``$KSM_CONFIG``
2. ``~/.keeper/caravan-ksm-config.json`` (personal KSM client)
3. ``~/Downloads/Cursor tests/keeper-vault-rbi-pam-testenv/ksm-config.json``
   (lab tenant KSM client)

Each KSM client has a different shared-folder grant — pick the config whose
client has access to the record(s) you need. The lab client owns the admin
login record (UID ``MyiZN4cw-wtEIpY1jHlhLw``); the personal client owns
personal vault records.

Hardening:

- Functions return values; **callers** decide whether to log them. The
  library itself logs only field type/label/has_value tuples (never values).
- ``parse_totp_secret`` extracts the ``secret`` query param from an
  ``oneTimeCode`` (``otpauth://``) URI without echoing the URI.
- The library imports ``keeper_secrets_manager_core`` lazily so test runs
  that never touch KSM stay dependency-free.
"""

from __future__ import annotations

import os
import sys
from pathlib import Path
from typing import Any, Iterable
from urllib.parse import parse_qs, urlparse


CONFIG_PROBES: tuple[Path, ...] = (
    Path.home() / ".keeper" / "caravan-ksm-config.json",
    Path.home() / "Downloads" / "Cursor tests" / "keeper-vault-rbi-pam-testenv" / "ksm-config.json",
)


def _resolve_config_path(config_path: str | os.PathLike[str] | None) -> Path:
    if config_path:
        p = Path(config_path).expanduser()
        if not p.is_file():
            raise FileNotFoundError(f"KSM config not found at {p}")
        return p
    env = os.environ.get("KSM_CONFIG")
    if env:
        p = Path(env).expanduser()
        if p.is_file():
            return p
    for probe in CONFIG_PROBES:
        if probe.is_file():
            return probe
    raise FileNotFoundError(
        "no KSM config found; set KSM_CONFIG or place a ksm-config.json at "
        + " or ".join(str(p) for p in CONFIG_PROBES)
    )


def client(config_path: str | os.PathLike[str] | None = None):
    """Return a fresh SecretsManager bound to the chosen config file."""
    from keeper_secrets_manager_core import SecretsManager
    from keeper_secrets_manager_core.storage import FileKeyValueStorage

    cfg = _resolve_config_path(config_path)
    return SecretsManager(config=FileKeyValueStorage(str(cfg)))


def get_record(
    uid: str,
    *,
    config_path: str | os.PathLike[str] | None = None,
):
    sm = client(config_path)
    recs = sm.get_secrets([uid])
    if not recs:
        raise LookupError(
            f"KSM record {uid[:6]}... not visible to client at "
            f"{_resolve_config_path(config_path)} — wrong KSM app or no shared-folder grant"
        )
    return recs[0]


def get_field(
    uid: str,
    field_type: str,
    *,
    label: str | None = None,
    single: bool = True,
    config_path: str | os.PathLike[str] | None = None,
) -> Any:
    """Return a field value from a KSM record.

    ``field_type`` matches the typed-field name (``login``, ``password``,
    ``oneTimeCode``, ``url`` ...). When multiple fields share a type, pass
    ``label`` to disambiguate.
    """
    rec = get_record(uid, config_path=config_path)
    if label is None:
        return rec.field(field_type, single=single)
    blocks: list[dict[str, Any]] = []
    for src in (rec.dict.get("fields", []), rec.dict.get("custom", [])):
        for entry in src or []:
            if entry.get("type") == field_type and (entry.get("label") or "") == label:
                blocks.append(entry)
    if not blocks:
        raise LookupError(
            f"no field type={field_type!r} label={label!r} on record {uid[:6]}..."
        )
    values = blocks[0].get("value") or []
    if single:
        return values[0] if values else None
    return values


def parse_totp_secret(otpauth_uri: str) -> str:
    """Extract the ``secret`` query parameter from an ``otpauth://`` URI."""
    if not isinstance(otpauth_uri, str) or not otpauth_uri.startswith("otpauth://"):
        raise ValueError("not an otpauth:// URI")
    qs = parse_qs(urlparse(otpauth_uri).query)
    secrets = qs.get("secret") or []
    if not secrets:
        raise ValueError("otpauth:// URI has no `secret` query param")
    return secrets[0]


def keeper_login_creds(
    record_uid: str,
    *,
    config_path: str | os.PathLike[str] | None = None,
) -> tuple[str, str, str]:
    """Return (email, password, totp_secret) from a Keeper-login KSM record.

    Convention: the record carries fields ``login`` (email), ``password``,
    and ``oneTimeCode`` (``otpauth://`` URI). Mirrors the deploy_watcher
    pattern at the lab tenant.
    """
    rec = get_record(record_uid, config_path=config_path)
    email = rec.field("login", single=True)
    password = rec.field("password", single=True)
    otp_uri = rec.field("oneTimeCode", single=True)
    if not (email and password and otp_uri):
        raise LookupError(
            f"record {record_uid[:6]}... missing login/password/oneTimeCode fields"
        )
    return email, password, parse_totp_secret(otp_uri)


def emit_shell_export(
    record_uid: str,
    *,
    config_path: str | os.PathLike[str] | None = None,
    file: Any = None,
) -> None:
    """Print ``export KEEPER_EMAIL=...; export KEEPER_PASSWORD=...; ...`` lines.

    Suitable for shell ``eval``. Values are printed exactly once to ``file``
    (default stdout) and never logged elsewhere by this library. Callers
    should redirect to a tmpfile under ``$XDG_RUNTIME_DIR`` or pipe straight
    into ``eval`` — never write the export lines to a long-lived path.
    """
    out = file if file is not None else sys.stdout
    email, password, totp = keeper_login_creds(record_uid, config_path=config_path)
    print(f"export KEEPER_EMAIL={_shell_quote(email)}", file=out)
    print(f"export KEEPER_PASSWORD={_shell_quote(password)}", file=out)
    print(f"export KEEPER_TOTP_SECRET={_shell_quote(totp)}", file=out)


def _shell_quote(s: str) -> str:
    if not s:
        return "''"
    return "'" + s.replace("'", "'\\''") + "'"


def describe_record(
    uid: str,
    *,
    config_path: str | os.PathLike[str] | None = None,
) -> dict[str, Any]:
    """Return field metadata only (type, label, has_value). No values.

    Use for probe/audit prompts that must not echo secret material.
    """
    rec = get_record(uid, config_path=config_path)
    return {
        "uid_prefix": uid[:6] + "..." if len(uid) > 6 else uid,
        "title_prefix": (rec.title or "")[:8] + "..." if rec.title else "(no title)",
        "fields": [
            {
                "type": f.get("type"),
                "label": f.get("label") or "",
                "has_value": bool(f.get("value")),
            }
            for f in rec.dict.get("fields", [])
        ],
        "custom": [
            {
                "type": f.get("type"),
                "label": f.get("label") or "",
                "has_value": bool(f.get("value")),
            }
            for f in rec.dict.get("custom", [])
        ],
    }


def _ensure_ksm_path() -> None:
    """Add this script's directory to sys.path so ``import ksm_lib`` works
    when callers ``cd`` to arbitrary repos before invoking helpers."""
    here = str(Path(__file__).resolve().parent)
    if here not in sys.path:
        sys.path.insert(0, here)


_ensure_ksm_path()


if __name__ == "__main__":
    import argparse

    p = argparse.ArgumentParser(description="Daybook KSM helper (operator surface)")
    sub = p.add_subparsers(dest="cmd", required=True)

    p_describe = sub.add_parser("describe", help="dump record schema (no values)")
    p_describe.add_argument("--uid", required=True)
    p_describe.add_argument("--config", default=None)

    p_export = sub.add_parser(
        "export-keeper",
        help="emit `export KEEPER_EMAIL=...` lines for shell eval",
    )
    p_export.add_argument("--uid", required=True)
    p_export.add_argument("--config", default=None)

    p_field = sub.add_parser("field", help="print one field value (use sparingly)")
    p_field.add_argument("--uid", required=True)
    p_field.add_argument("--type", required=True)
    p_field.add_argument("--label", default=None)
    p_field.add_argument("--config", default=None)

    args = p.parse_args()
    if args.cmd == "describe":
        import json as _json

        print(_json.dumps(describe_record(args.uid, config_path=args.config), indent=2))
    elif args.cmd == "export-keeper":
        emit_shell_export(args.uid, config_path=args.config)
    elif args.cmd == "field":
        v = get_field(
            args.uid,
            args.type,
            label=args.label,
            single=True,
            config_path=args.config,

