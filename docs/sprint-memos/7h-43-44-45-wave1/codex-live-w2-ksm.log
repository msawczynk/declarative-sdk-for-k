run_id = os.environ["RUN_ID"]
source_config = os.environ["KEEPER_SDK_KSM_CONFIG"]
admin_uid = os.environ["KEEPER_SDK_KSM_CREDS_RECORD_UID"]
config_out = Path("/tmp") / f"dsk-ksm-l1-{commit_short}-{run_id}-ksm-config.json"
app_name = f"dsk-ksm-l1-{commit_short}"
bus_title = f"dsk-ksm-l1-bus-{commit_short}"

started_at = datetime.now(UTC).isoformat(timespec="seconds").replace("+00:00", "Z")
events: list[dict[str, Any]] = []


def fp(value: str, prefix: str = "sha256") -> str:
    return f"<{prefix}:{hashlib.sha256(value.encode('"'utf-8')).hexdigest()[:8]}>\"


def value_hash(value: str) -> str:
    return hashlib.sha256(value.encode(\"utf-8\")).hexdigest()[:8]


def elapsed_ms(t0: float) -> int:
    return int((time.monotonic() - t0) * 1000)


def event(name: str, t0: float | None = None, **details: Any) -> None:
    row: dict[str, Any] = {\"event\": name, \"result\": \"ok\"}
    if t0 is not None:
        row[\"elapsed_ms\"] = elapsed_ms(t0)
    row.update(details)
    events.append(row)


def field_shape(desc: dict[str, Any], block: str) -> list[dict[str, Any]]:
    return [
        {\"type\": item.get(\"type\"), \"label\": item.get(\"label\") or \"\", \"has_value\": bool(item.get(\"has_value\"))}
        for item in desc.get(block, [])
    ]

try:
    t0 = time.monotonic()
    helper = KsmLoginHelper()
    creds = helper.load_keeper_creds()
    source_store = KsmSecretStore(config_path=source_config)
    source_desc = source_store.describe(admin_uid)
    event(
        \"ksm_login_helper_load\",
        t0,
        record_uid_hash=fp(admin_uid, \"uid\"),
        source_config_basename=Path(source_config).name,
        fields=field_shape(source_desc, \"fields\"),
    )

    t0 = time.monotonic()
    params = helper.keeper_login(**creds)
    event(
        \"commander_login\",
        t0,
        server=getattr(params, \"server\", \"\") or os.environ.get(\"KEEPER_SERVER\", \"\"),
        session=\"established\",
    )

    t0 = time.monotonic()
    result = bootstrap_ksm_application(
        params=params,
        app_name=app_name,
        admin_record_uid=admin_uid,
        config_out=config_out,
        first_access_minutes=10,
        unlock_ip=False,
        create_bus_directory=True,
        bus_directory_title=bus_title,
        overwrite=True,
    )
    if not result.bus_directory_uid:
        raise RuntimeError(\"bootstrap did not return a bus directory uid\")
    event(
        \"bootstrap_ksm_application\",
        t0,
        app_uid_hash=fp(result.app_uid, \"uid\"),
        admin_record_uid_hash=fp(result.admin_record_uid, \"uid\"),
        bus_directory_uid_hash=fp(result.bus_directory_uid, \"uid\"),
        config_out_basename=Path(result.config_path).name,
        client_token_redeemed=result.client_token_redeemed,
        created_admin_record=result.created_admin_record,
        created_bus_directory=result.created_bus_directory,
        expires_at_present=bool(result.expires_at_iso),
    )

    t0 = time.monotonic()
    proof_store = KsmSecretStore(config_path=result.config_path)
    admin_desc = proof_store.describe(admin_uid)
    bus_desc = proof_store.describe(result.bus_directory_uid)
    event(
        \"sample_fetch\",
        t0,
        admin_fields=field_shape(admin_desc, \"fields\"),
        bus_custom=field_shape(bus_desc, \"custom\"),
    )

    t0 = time.monotonic()
    record = proof_store.get_record(result.bus_directory_uid)
    original = record.custom_field(label=\"topics\", single=True)
    if original is None:
        original = \"{}\"
    if not isinstance(original, str):
        original = json.dumps(original, sort_keys=True, separators=(\",\", \":\"))
    try:
        parsed = json.loads(original) if original else {}
    except json.JSONDecodeError:
        parsed = {\"previous_non_json_len\": len(original)}
    if not isinstance(parsed, dict):
        parsed = {\"previous_json_type\": type(parsed).__name__}
    updated = dict(parsed)
    updated[\"ksm_l1_round_trip\"] = {
        \"commit\": commit_short,
        \"commander_pin\": commander_pin[:8],
        \"run_id_hash\": value_hash(run_id),
        \"updated_at\": started_at,
    }
    updated_json = json.dumps(updated, sort_keys=True, separators=(\",\", \":\"))
    record.custom_field(label=\"topics\", value=updated_json, field_type=\"json\")
    proof_store.client().save(record)
    event(
        \"write_update\",
        t0,
        record_uid_hash=fp(result.bus_directory_uid, \"uid\"),
        field_type=\"json\",
        field_label=\"topics\",
        original_len=len(original),
        updated_len=len(updated_json),
        updated_hash=value_hash(updated_json),
    )

    t0 = time.monotonic()
    verify_store = KsmSecretStore(config_path=result.config_path)
    verify_record = verify_store.get_record(result.bus_directory_uid)
    observed = verify_record.custom_field(label=\"topics\", single=True)
    if observed "'!= updated_json:
        raise RuntimeError("KSM fetch-back did not match updated topics field")
    event("fetch_back", t0, value_hash=value_hash(observed), value_len=len(observed))

    t0 = time.monotonic()
    verify_record.custom_field(label="topics", value=original, field_type="json")
    verify_store.client().save(verify_record)
    restored_store = KsmSecretStore(config_path=result.config_path)
    restored_record = restored_store.get_record(result.bus_directory_uid)
    restored = restored_record.custom_field(label="topics", single=True)
    if restored != original:
        raise RuntimeError("KSM restore fetch-back did not match original topics field")
    event("restore", t0, restored=True, value_hash=value_hash(restored or ""), value_len=len(restored or ""))

    finished_at = datetime.now(UTC).isoformat(timespec="seconds").replace("+00:00", "Z")
    payload = {
        "family": "keeper-ksm.v1",
        "scenario": "ksmLoginHelperBootstrapRoundTrip",
        "commit": commit,
        "commander_pin": commander_pin,
        "commander_version": version("keepercommander"),
        "keeper_secrets_manager_core_version": version("keeper-secrets-manager-core"),
        "tenant_hash": hashlib.sha256(os.environ.get("KEEPER_EMAIL", "").encode("utf-8")).hexdigest()[-8:],
        "started_at": started_at,
        "finished_at": finished_at,
        "notes": [
            "L1 live pass: KsmLoginHelper loaded credentials from KSM, authenticated Commander, bootstrapped a KSM app/config, and redeemed a client.",
            "Redeemed KSM client fetched the shared admin record, updated the editable bus topics field, fetched back the new value, then restored the original value. In-run self-fix: bound redeemed KSM configs with an initial quiet get_secrets call before verification.",
        ],
        "events": events,
    }
    text = json.dumps(payload, indent=2, sort_keys=True) + "'"\\n\"
    leaks = secret_leak_check(
        text,
        env_keys=(
            \"KEEPER_EMAIL\",
            \"KEEPER_PASSWORD\",
            \"KEEPER_TOTP_SECRET\",
            \"KEEPER_SDK_KSM_CONFIG\",
            \"KEEPER_SDK_KSM_CREDS_RECORD_UID\",
            \"KSM_CONFIG\",
            \"KSM_CREDS_RECORD_UID\",
        ),
    )
    if leaks:
        raise RuntimeError(f\"sanitized payload failed leak check: {leaks}\")
    out = Path(os.environ[\"DSK_KSM_L1_RAW_EVENTS\"])
    out.write_text(text, encoding=\"utf-8\")
    print(json.dumps({\"status\": \"ok\", \"events_path\": str(out), \"event_count\": len(events)}, sort_keys=True))
except Exception as exc:
    failure = {
        \"status\": \"failed\",
        \"error_type\": type(exc).__name__,
        \"error\": str(exc)[:500],
        \"events\": events,
    }
    print(json.dumps(failure, indent=2, sort_keys=True))
    raise
