/bin/zsh -lc "sed -n '48,110p' pyproject.toml" in /Users/martin/Downloads/Cursor tests/declarative-sdk-for-k
 succeeded in 0ms:
Homepage = "https://github.com/msawczynk/declarative-sdk-for-k"
Issues = "https://github.com/msawczynk/declarative-sdk-for-k/issues"
Documentation = "https://github.com/msawczynk/declarative-sdk-for-k#readme"

[project.optional-dependencies]
dev = [
    "pytest>=7.0",
    "pytest-cov",
    "mypy",
    "ruff",
    "types-PyYAML",
    "types-jsonschema",
]
ksm = [
    "keeper-secrets-manager-core>=17.2.0,<18",
]

[project.scripts]
# Short, tab-completable, agent-friendly. Primary CLI name.
dsk = "keeper_sdk.cli:main"
# Backwards-compat aliases for pre-1.0 callers + CI scripts. Will be
# removed in v2.0.0 when the package is also renamed to `declarative_sdk_k`.
pamform = "keeper_sdk.cli:main"
keeper-sdk = "keeper_sdk.cli:main"

[tool.setuptools]
include-package-data = true

[tool.setuptools.packages.find]
include = ["keeper_sdk*"]
exclude = ["tests*"]

[tool.setuptools.package-data]
"keeper_sdk.core.schemas" = ["*.json", "**/*.json"]

[tool.mypy]
python_version = "3.11"
ignore_missing_imports = true
check_untyped_defs = true
# yaml stubs live in types-PyYAML (dev dep); silence on systems where
# someone runs mypy without installing the dev extra.
[[tool.mypy.overrides]]
module = ["yaml", "yaml.*"]
ignore_missing_imports = true
follow_imports = "skip"

[tool.ruff]
target-version = "py311"
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "W", "I", "UP"]
ignore = ["E501"]

[tool.pytest.ini_options]
testpaths = ["tests"]
markers = [
    "integration: requires a live Keeper tenant (set KEEPER_CONFIG)",
    "slow: perf / long tests",
]

[tool.coverage.run]
omit = ["keeper_sdk/secrets/bus.py"]

