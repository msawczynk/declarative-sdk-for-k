+schema: keeper-vault.v1
+
+# Custom record-type definitions. These are schema-validated offline; provider
+# lifecycle coverage for record_types[] is intentionally separate from login L1.
+#
+# Run:
+#   dsk validate examples/vault-record-types.yaml
+
+record_types:
+  - uid_ref: rt.service-account
+    scope: enterprise
+    record_type_id: 3001001
+    content:
+      $id: serviceAccount
+      categories: ["login"]
+      description: "Service account credential"
+      fields:
+        - $ref: login
+          label: Username
+          required: true
+        - $ref: password
+          label: Password
+          required: true
+        - $ref: host
+          label: Endpoint
+
+  - uid_ref: rt.break-glass-admin
+    scope: enterprise
+    record_type_id: 3001002
+    content:
+      $id: breakGlassAdmin
+      categories: ["login", "admin"]
+      description: "Emergency access credential"
+      fields:
+        - $ref: login
+          required: true
+        - $ref: password
+          required: true
+        - $ref: securityQuestion
+          label: Recovery Question
diff --git a/examples/vault-records.yaml b/examples/vault-records.yaml
new file mode 100644
index 0000000000000000000000000000000000000000..6409f329e043a286bc394ef2229850741045cfbb
--- /dev/null
+++ b/examples/vault-records.yaml
@@ -0,0 +1,99 @@
+schema: keeper-vault.v1
+
+# Five validate-clean vault records. The current CLI validator typed-loads
+# keeper-vault.v1 through the L1 login lifecycle, so these stay type: login
+# while demonstrating field payloads commonly needed for login, credit-card,
+# database-credential, server-credential, and custom record examples.
+#
+# Run:
+#   dsk validate examples/vault-records.yaml
+#   dsk plan     examples/vault-records.yaml --provider mock --json
+
+records:
+  - uid_ref: rec.login.web-admin
+    type: login
+    title: "Example Web Admin"
+    fields:
+      - type: login
+        label: Login
+        value: ["web-admin@example.invalid"]
+      - type: password
+        label: Password
+        value: ["example-password"]
+      - type: url
+        label: URL
+        value: ["https://admin.example.invalid"]
+
+  - uid_ref: rec.credit-card.ops
+    type: login
+    title: "Example Credit Card"
+    fields:
+      - type: paymentCard
+        label: Payment Card
+        value:
+          - cardNumber: "test-card-number"
+            cardExpirationDate: "01/2030"
+            cardSecurityCode: "000"
+    custom:
+      - type: text
+        label: Cost Center
+        value: ["operations"]
+
+  - uid_ref: rec.database.credentials
+    type: login
+    title: "Example Database Credentials"
+    fields:
+      - type: login
+        label: Username
+        value: ["orders_app"]
+      - type: password
+        label: Password
+        value: ["example-db-password"]
+      - type: host
+        label: Host
+        value:
+          - hostName: db.example.invalid
+            port: 5432
+    custom:
+      - type: text
+        label: Database
+        value: ["orders"]
+
+  - uid_ref: rec.server.credentials
+    type: login
+    title: "Example Server Credentials"
+    fields:
+      - type: login
+        label: Username
+        value: ["svc-deploy"]
+      - type: host
+        label: Host
+        value:
+          - hostName: app.example.invalid
+            port: "22"
+      - type: keyPair
+        label: SSH Key
+        value:
+          - publicKey: "ssh-ed25519 example-public-key"
+            privateKey: "example-private-key"
+
+  - uid_ref: rec.custom.asset
+    type: login
+    title: "Example Custom Asset"
+    notes: "Custom metadata-only example with typed custom fields."
+    fields:
+      - type: text
+        label: Asset Tag
+        value: ["asset-12345"]
+    custom:
+      - type: name
+        label: Owner
+        value:
+          - first: Example
+            last: Owner
+      - type: phone
+        label: Support Phone
+        value:
+          - region: US
+            number: "5550100"
+            type: Work
diff --git a/tests/test_examples_validate.py b/tests/test_examples_validate.py
new file mode 100644
index 0000000000000000000000000000000000000000..7c4d124a9ddb454bd1132476315dea9602b01cca
--- /dev/null
+++ b/tests/test_examples_validate.py
@@ -0,0 +1,31 @@
+"""Validation coverage for root ``examples/*.yaml`` manifests."""
+
+from __future__ import annotations
+
+from pathlib import Path
+
+import pytest
+
+from keeper_sdk.core.manifest import read_manifest_document
+from keeper_sdk.core.schema import validate_manifest
+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+EXAMPLES_DIR = REPO_ROOT / "examples"
+EXAMPLE_MANIFESTS: tuple[Path, ...] = tuple(sorted(EXAMPLES_DIR.glob("*.yaml")))
+
+
+def _example_id(manifest_path: Path) -> str:
+    return manifest_path.name
+
+
+def test_root_examples_exist() -> None:
+    assert len(EXAMPLE_MANIFESTS) >= 10
+
+
+@pytest.mark.parametrize("manifest_path", EXAMPLE_MANIFESTS, ids=_example_id)
+def test_root_example_validate_manifest_succeeds(manifest_path: Path) -> None:
+    document = read_manifest_document(manifest_path)
+
+    family = validate_manifest(document)
+
+    assert family

