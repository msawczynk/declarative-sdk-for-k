+        live_share_folders=live_by_type["sharing_share_folder"],
+        manifest_name=manifest_name,
+    )
+    blocking = [
+        change
+        for change in changes
+        if change.kind in (ChangeKind.CREATE, ChangeKind.UPDATE, ChangeKind.CONFLICT)
