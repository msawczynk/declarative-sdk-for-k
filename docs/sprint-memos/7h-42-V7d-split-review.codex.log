   393	                resource_type=_SHARING_FOLDER_RESOURCE,
   394	                title=title,
   395	                keeper_uid=live.keeper_uid,
   396	                before=live.payload,
   397	                reason="managed folder missing from manifest; pass --allow-delete to remove",
   398	                manifest_name=manifest_name,
   399	            )
   400	        )
