   524	
   525	def _classify_orphans(
   526	    live_records: list[LiveRecord],
   527	    *,
   528	    matched: set[str],
   529	    manifest_name: str,
   530	    allow_delete: bool,
   531	) -> list[Change]:
   532	    """Emit DELETE / CONFLICT rows for records that went unmatched.
   533	
   534	    Only this-manifest-managed records are considered. Foreign-managed
   535	    and unmanaged records silently fall through — the SDK refuses to
   536	    remove anything it did not create.
   537	    """
   538	    out: list[Change] = []
   539	    for live in live_records:
   540	        if live.keeper_uid in matched:
   541	            continue
   542	        marker = live.marker or {}
   543	        if marker.get("manager") != MANAGER_NAME:
   544	            continue
   545	        if marker.get("manifest") and manifest_name and marker.get("manifest") != manifest_name:
   546	            continue
   547	        if allow_delete:
   548	            out.append(
   549	                Change(
   550	                    kind=ChangeKind.DELETE,
   551	                    uid_ref=marker.get("uid_ref"),
   552	                    resource_type=live.resource_type,
   553	                    title=live.title,
   554	                    keeper_uid=live.keeper_uid,
   555	                    before=live.payload,
   556	                )
   557	            )
   558	        else:
   559	            out.append(
   560	                Change(
   561	                    kind=ChangeKind.CONFLICT,
   562	                    uid_ref=marker.get("uid_ref"),
   563	                    resource_type=live.resource_type,
   564	                    title=live.title,
   565	                    keeper_uid=live.keeper_uid,
   566	                    reason="managed record missing from manifest; pass --allow-delete to remove",
   567	                )
   568	            )
   569	    return out
   570	
   571	
   572	def _raise_live_record_collisions(live_records: list[LiveRecord]) -> None:
   573	    """Reject ambiguous live-record matches before diffing desired state."""
   574	    marker_matches: dict[str, list[LiveRecord]] = {}
   575	    title_matches: dict[tuple[str, str], list[LiveRecord]] = {}
   576	
   577	    for live in live_records:
   578	        marker_uid_ref = (live.marker or {}).get("uid_ref") if live.marker else None
   579	        if marker_uid_ref:
   580	            marker_matches.setdefault(marker_uid_ref, []).append(live)
   581	        title_matches.setdefault((live.resource_type, live.title), []).append(live)
   582	
   583	    for uid_ref, matches in marker_matches.items():
   584	        if len(matches) < 2:
   585	            continue
   586	        raise CollisionError(
   587	            reason=f"live tenant has {len(matches)} records claiming uid_ref='{uid_ref}'",
   588	            uid_ref=uid_ref,
   589	            next_action="reconcile the duplicate ownership markers manually before re-running apply",
   590	            context={"live_identifiers": [live.keeper_uid for live in matches]},
   591	        )
   592	
   593	    for (resource_type, title), matches in title_matches.items():
   594	        if len(matches) < 2:
   595	            continue
   596	        if any((live.marker or {}).get("uid_ref") for live in matches):
   597	            continue
   598	        raise CollisionError(
   599	            reason=f"live tenant has {len(matches)} {resource_type} records titled '{title}' with no ownership markers",
   600	            uid_ref=None,
   601	            resource_type=resource_type,
   602	            next_action="rename duplicates or add ownership markers so matching is unambiguous",
   603	            context={"live_identifiers": [live.keeper_uid for live in matches]},
   604	        )
   605	
   606	
   607	_DIFF_IGNORED_FIELDS = frozenset(
   608	    {
   609	        "uid_ref",
   610	        "attachments",
   611	        "scripts",
   612	        "custom_fields",
   613	        "record_uid",
   614	        # SDK-only placement/linkage metadata — not record fields and never
   615	        # observable from Commander `get`. Keep them out of the planner diff so
   616	        # re-plans are clean when fields match.
   617	        "pam_configuration",
   618	        "pam_configuration_uid_ref",
   619	        "shared_folder",
   620	        "users",
   621	        "gateway",
   622	        "gateway_uid_ref",
   623	    }
   624	)
   625	
   626	
   627	def _field_diff(before: dict[str, Any], after: dict[str, Any]) -> list[str]:
   628	    """Return keys whose value differs. Only compare overlapping canonical keys."""
   629	    keys: set[str] = set(before) | set(after)
   630	    changed: list[str] = []
   631	    for key in keys:
   632	        if key in _DIFF_IGNORED_FIELDS:
   633	            continue
   634	        # only treat a key as changed if the desired side actually set it; this
   635	        # avoids churn on fields the caller doesn't manage.
   636	        if key not in after:
   637	            continue
   638	        if before.get(key) != after.get(key):
   639	            changed.append(key)
   640	    return sorted(changed)
   641	
   642	
   643	__all__ = ["Change", "ChangeKind", "compute_diff", "CollisionError"]

