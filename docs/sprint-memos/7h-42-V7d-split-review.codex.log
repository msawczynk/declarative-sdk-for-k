   484	            uid_ref=uid_ref or None,
   485	            resource_type=resource_type,
   486	            title=title,
   487	            keeper_uid=live.keeper_uid,
   488	            before=live.payload,
   489	            after=payload,
   490	            reason="adoption: write ownership marker",
   491	        )
   492	
   493	    if vault_login_diff and resource_type == "login":
   494	        diff_fields = _field_diff_vault_login(live.payload, payload)
   495	    elif resource_type == "pamRemoteBrowser":
   496	        diff_fields = _field_diff_pam_remote_browser(live.payload, payload)
   497	    elif resource_type == "pamUser":
   498	        diff_fields = _field_diff_pam_user(
   499	            live.payload,
   500	            payload,
   501	            marker=live.marker,
   502	            uid_ref=uid_ref,
   503	        )
   504	    else:
   505	        diff_fields = _field_diff(live.payload, payload)
   506	    if not diff_fields:
   507	        return Change(
   508	            kind=ChangeKind.NOOP,
   509	            uid_ref=uid_ref or None,
   510	            resource_type=resource_type,
   511	            title=title,
   512	            keeper_uid=live.keeper_uid,
   513	        )
   514	    return Change(
   515	        kind=ChangeKind.UPDATE,
   516	        uid_ref=uid_ref or None,
   517	        resource_type=resource_type,
   518	        title=title,
   519	        keeper_uid=live.keeper_uid,
   520	        before={k: live.payload.get(k) for k in diff_fields},
   521	        after={k: payload.get(k) for k in diff_fields},
   522	    )
