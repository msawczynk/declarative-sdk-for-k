   701	def _grantee_parts(payload: dict[str, Any]) -> tuple[str | None, str | None]:
   702	    grantee = payload.get("grantee")
   703	    if isinstance(grantee, dict):
   704	        kind = grantee.get("kind")
   705	        if kind == "user" and grantee.get("user_email") is not None:
   706	            return "user", str(grantee["user_email"])
   707	        if kind == "team" and grantee.get("team_uid_ref") is not None:
   708	            return "team", str(grantee["team_uid_ref"])
   709	
   710	    if payload.get("user_email") is not None:
   711	        return "user", str(payload["user_email"])
   712	    if payload.get("team_uid_ref") is not None:
   713	        return "team", str(payload["team_uid_ref"])
   714	    return None, None
   715	
