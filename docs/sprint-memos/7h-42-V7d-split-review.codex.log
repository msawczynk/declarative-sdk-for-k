   285	def _compute_folders_changes(
   286	    manifest: SharingManifestV1,
   287	    live_folders: list[dict[str, Any]],
   288	    *,
   289	    manifest_name: str = "vault-sharing",
   290	    allow_delete: bool = False,
   291	) -> list[Change]:
   292	    desired_by_uid_ref = _index_manifest_folders(manifest)
   293	    live_by_uid_ref, live_by_path, indexed_live = _index_live_folders(live_folders)
   294	
   295	    changes: list[Change] = []
   296	    matched: set[int] = set()
   297	
   298	    for uid_ref, desired_payload in desired_by_uid_ref.items():
   299	        path = _folder_path(desired_payload)
   300	        live = live_by_uid_ref.get(uid_ref) or (live_by_path.get(path) if path else None)
   301	        title = _folder_title(desired_payload, uid_ref)
   302	        if live is None:
   303	            changes.append(
   304	                Change(
   305	                    kind=ChangeKind.ADD,
   306	                    uid_ref=uid_ref,
   307	                    resource_type=_SHARING_FOLDER_RESOURCE,
   308	                    title=title,
   309	                    after=_desired_folder_payload(
   310	                        desired_payload,
   311	                        manifest_name=manifest_name,
   312	                    ),
   313	                    manifest_name=manifest_name,
   314	                )
   315	            )
   316	            continue
   317	
