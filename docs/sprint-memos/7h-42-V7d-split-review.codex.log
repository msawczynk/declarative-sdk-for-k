   717	def _record_share_payload(raw: dict[str, Any]) -> dict[str, Any]:
   718	    payload = dict(raw)
   719	    permissions = payload.get("permissions")
   720	    permissions = permissions if isinstance(permissions, dict) else {}
   721	    for field in ("can_edit", "can_share"):
   722	        if field not in payload and field in permissions:
   723	            payload[field] = permissions[field]
   724	
   725	    grantee_kind, grantee_identifier = _grantee_parts(payload)
   726	    if grantee_kind == "user" and grantee_identifier is not None:
   727	        payload.setdefault("user_email", grantee_identifier)
   728	    elif grantee_kind == "team" and grantee_identifier is not None:
   729	        payload.setdefault("team_uid_ref", grantee_identifier)
   730	    return payload
   731	
   732	
   733	def _record_share_key(payload: dict[str, Any]) -> tuple[str, str]:
   734	    record_uid_ref = _payload_str(payload, "record_uid_ref")
   735	    if not record_uid_ref:
   736	        raise ValueError("record_share missing record_uid_ref")
   737	    _, grantee_identifier = _grantee_parts(payload)
   738	    if not grantee_identifier:
   739	        raise ValueError("record_share missing grantee")
   740	    return (record_uid_ref, grantee_identifier)
   741	
   742	
   743	def _record_share_title(payload: dict[str, Any]) -> str:
   744	    record_uid_ref, grantee_identifier = _record_share_key(payload)
   745	    return f"{record_uid_ref}:{grantee_identifier}"
   746	
   747	
   748	def _desired_record_share_payload(
   749	    payload: dict[str, Any],
   750	    *,
   751	    manifest_name: str,
   752	) -> dict[str, Any]:
   753	    out = dict(payload)
   754	    out["marker"] = encode_marker(
   755	        uid_ref=str(payload["uid_ref"]),
   756	        manifest=manifest_name,
   757	        resource_type=_RECORD_SHARE_RESOURCE,
   758	        parent_uid_ref=str(payload["record_uid_ref"]),
   759	    )
   760	    return out
   761	
   762	
   763	def _index_manifest_record_shares(
   764	    manifest: SharingManifestV1,
   765	) -> tuple[dict[tuple[str, str], dict[str, Any]], dict[str, dict[str, Any]]]:
   766	    by_key: dict[tuple[str, str], dict[str, Any]] = {}
   767	    by_uid_ref: dict[str, dict[str, Any]] = {}
   768	    for record_share in manifest.share_records:
   769	        payload = _record_share_payload(record_share.model_dump(mode="python", exclude_none=True))
   770	        uid_ref = str(payload["uid_ref"])
   771	        if uid_ref in by_uid_ref:
   772	            raise ValueError(f"duplicate manifest record_share uid_ref: {uid_ref}")
   773	        key = _record_share_key(payload)
   774	        if key in by_key:
   775	            raise ValueError(f"duplicate manifest record_share key: {key}")
   776	        by_uid_ref[uid_ref] = payload
   777	        by_key[key] = payload
   778	    return by_key, by_uid_ref
