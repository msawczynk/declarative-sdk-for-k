   320	            live.marker,
   321	            uid_ref=live.uid_ref,
   322	            manifest_name=manifest_name,
   323	        ):
   324	            changes.append(
   325	                Change(
   326	                    kind=ChangeKind.SKIP,
   327	                    uid_ref=uid_ref,
   328	                    resource_type=_SHARING_FOLDER_RESOURCE,
   329	                    title=title,
   330	                    keeper_uid=live.keeper_uid,
   331	                    before=live.payload,
   332	                    reason="unmanaged folder",
   333	                    manifest_name=manifest_name,
   334	                )
   335	            )
   336	            continue
   337	
   338	        diff_fields = _folder_diff_fields(live.payload, desired_payload)
   339	        if diff_fields:
   340	            changes.append(
   341	                Change(
   342	                    kind=ChangeKind.UPDATE,
   343	                    uid_ref=uid_ref,
   344	                    resource_type=_SHARING_FOLDER_RESOURCE,
   345	                    title=title,
   346	                    keeper_uid=live.keeper_uid,
   347	                    before={field: live.payload.get(field) for field in diff_fields},
   348	                    after={field: desired_payload.get(field) for field in diff_fields},
   349	                    manifest_name=manifest_name,
   350	                )
   351	            )
   352	
   353	    for live in indexed_live:
   354	        if live.index in matched:
   355	            continue
   356	        orphan_uid_ref = live.uid_ref or _folder_path(live.payload)
   357	        title = _folder_title(live.payload, orphan_uid_ref)
   358	        if not _folder_managed_by_manifest(
   359	            live.marker,
   360	            uid_ref=orphan_uid_ref,
   361	            manifest_name=manifest_name,
   362	        ):
   363	            changes.append(
   364	                Change(
   365	                    kind=ChangeKind.SKIP,
   366	                    uid_ref=orphan_uid_ref,
   367	                    resource_type=_SHARING_FOLDER_RESOURCE,
   368	                    title=title,
   369	                    keeper_uid=live.keeper_uid,
   370	                    before=live.payload,
   371	                    reason="unmanaged folder",
   372	                    manifest_name=manifest_name,
   373	                )
   374	            )
   375	            continue
   376	        if allow_delete:
   377	            changes.append(
   378	                Change(
   379	                    kind=ChangeKind.DELETE,
   380	                    uid_ref=orphan_uid_ref,
   381	                    resource_type=_SHARING_FOLDER_RESOURCE,
   382	                    title=title,
   383	                    keeper_uid=live.keeper_uid,
   384	                    before=live.payload,
   385	                    manifest_name=manifest_name,
   386	                )
   387	            )
   388	            continue
   389	        changes.append(
   390	            Change(
   391	                kind=ChangeKind.SKIP,
