  1941	    def _can_attempt_in_process_login(self) -> bool:
  1942	        """True when in-process Commander login is plausibly available.
  1943	
  1944	        Checked before routing read-side commands (``ls``/``get``) through
  1945	        the in-process path. When False the dispatcher falls through to
  1946	        subprocess so plain installs (no helper, no env creds) keep working.
  1947	        """
  1948	        if self._keeper_params is not None:
  1949	            return True
  1950	        if self._keeper_login_attempted:
  1951	            return False
  1952	        if os.environ.get("KEEPER_SDK_LOGIN_HELPER"):
  1953	            return True
  1954	        env_creds = ("KEEPER_EMAIL", "KEEPER_PASSWORD", "KEEPER_TOTP_SECRET")
  1955	        if all(os.environ.get(v) for v in env_creds):
  1956	            return True
  1957	        return False
