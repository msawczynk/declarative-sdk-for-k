   124	def _do(admin_params, command: str) -> str:
   125	    """Run a keeper CLI command via cli.do_command, capturing stdout.
   126	
   127	    Commander CLI subcommands print results directly to stdout (tabulate /
   128	    json.dump) and usually return None. We redirect stdout into a buffer so the
   129	    caller sees the actual payload and the terminal stays clean.
   130	    """
