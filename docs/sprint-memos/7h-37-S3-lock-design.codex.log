   462	    lines = text.splitlines()
   463	    omitted = max(0, len(lines) - max_lines)
   464	    tail = "\n".join(lines[-max_lines:])
   465	    if omitted:
   466	        return f"... ({omitted} line(s) omitted)\n{tail}"
