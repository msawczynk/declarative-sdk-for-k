   446	def _auth_path_message(login_helper: str, *, helper_path: str | None = None) -> str:
   447	    if login_helper == "env":
   448	        return (
   449	            "sdk auth path: public EnvLoginHelper env path "
   450	            "(KEEPER_EMAIL/KEEPER_PASSWORD/KEEPER_TOTP_SECRET; "
   451	            "KEEPER_SDK_LOGIN_HELPER unset)"
   452	        )
   453	    if login_helper == "deploy_watcher":
   454	        suffix = f" ({helper_path})" if helper_path else ""
   455	        return f"sdk auth path: deploy_watcher helper path via KEEPER_SDK_LOGIN_HELPER{suffix}"
   456	    raise ValueError(f"unknown login helper: {login_helper}")
