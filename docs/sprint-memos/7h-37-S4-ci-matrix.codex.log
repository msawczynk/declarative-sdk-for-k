   403	def _sdk(args: list[str], *, env: dict[str, str]) -> None:
   404	    _sdk_allow([0], args, env=env)
   405	
   406	
   407	def _sdk_allow(ok_codes: list[int], args: list[str], *, env: dict[str, str]) -> int:
   408	    cmd = [sys.executable, "-m", "keeper_sdk.cli", "--provider", "commander", *args]
   409	    log.info("SDK: %s", " ".join(cmd))
   410	    result = subprocess.run(
   411	        cmd,
   412	        cwd=ROOT,
   413	        env=env,
   414	        check=False,
   415	        capture_output=True,
   416	        text=True,
   417	        stdin=subprocess.DEVNULL,
   418	    )
   419	    if result.returncode not in ok_codes:
   420	        stdout_tail = _tail_text(result.stdout)
   421	        stderr_tail = _tail_text(result.stderr)
   422	        if result.returncode == 5:
   423	            raise TenantConstraintError(
   424	                _format_sdk_failure(
   425	                    "sdk command reported tenant/provider constraint",
   426	                    command=cmd,
   427	                    returncode=result.returncode,
   428	                    stdout_tail=stdout_tail,
   429	                    stderr_tail=stderr_tail,
   430	                )
   431	            )
   432	        raise SdkCommandError(
   433	            args=args,
   434	            command=cmd,
   435	            returncode=result.returncode,
   436	            stdout=result.stdout,
   437	            stderr=result.stderr,
   438	        )
   439	    if result.stdout:
   440	        log.debug("SDK stdout tail:\n%s", _tail_text(result.stdout))
   441	    if result.stderr:
   442	        log.debug("SDK stderr tail:\n%s", _tail_text(result.stderr))
   443	    return result.returncode
