   470	def _format_sdk_failure(
   471	    prefix: str,
   472	    *,
   473	    command: list[str],
   474	    returncode: int,
   475	    stdout_tail: str,
   476	    stderr_tail: str,
   477	) -> str:
   478	    return "\n".join(
   479	        [
   480	            f"{prefix}: exit_code={returncode}",
   481	            f"command: {_quote_cmd(command)}",
   482	            "stdout_tail:",
   483	            stdout_tail,
   484	            "stderr_tail:",
   485	            stderr_tail,
   486	        ]
   487	    )
