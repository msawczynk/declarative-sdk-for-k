   494	def _load_admin_creds() -> tuple[str, str, str]:
   495	    """Re-fetch admin creds via deploy_watcher.load_keeper_creds().
   496	
   497	    KeeperParams zeroes .password after successful login, so we can't pull
   498	    the password off admin_params. Re-reading from KSM is cheap (~1s) and
   499	    lets the smoke runner exercise either login-helper path without
   500	    plumbing secrets through identity.admin_login()'s return.
   501	    """
   502	    module_path = identity.LAB_ROOT / "scripts" / "deploy_watcher.py"
   503	    deploy_watcher = identity._load_lab_module("sdk_smoke_admin_creds", module_path)
   504	    email, password, totp_secret = deploy_watcher.load_keeper_creds()
   505	    return email, password, totp_secret
