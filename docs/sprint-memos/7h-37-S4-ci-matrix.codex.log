   218	def _verify_database(records: Sequence[Any]) -> None:
   219	    for record in records:
   220	        if getattr(record, "resource_type", None) != "pamDatabase":
   221	            continue
   222	        payload = getattr(record, "payload", {}) or {}
   223	        if not payload.get("database_type"):
   224	            raise AssertionError(
   225	                f"pamDatabase {record.title} has no database_type in discovered payload"
   226	            )
   227	
   228	
   229	def _verify_directory(records: Sequence[Any]) -> None:
   230	    for record in records:
   231	        if getattr(record, "resource_type", None) != "pamDirectory":
   232	            continue
   233	        payload = getattr(record, "payload", {}) or {}
   234	        if not payload.get("directory_type"):
   235	            raise AssertionError(
   236	                f"pamDirectory {record.title} has no directory_type in discovered payload"
   237	            )
   238	
   239	
   240	def _verify_remote_browser(records: Sequence[Any]) -> None:
   241	    for record in records:
   242	        if getattr(record, "resource_type", None) != "pamRemoteBrowser":
   243	            continue
   244	        payload = getattr(record, "payload", {}) or {}
   245	        options = (payload.get("pam_settings") or {}).get("options") or {}
   246	        if options.get("remote_browser_isolation") != "on":
   247	            raise AssertionError(
   248	                f"pamRemoteBrowser {record.title} did not retain remote_browser_isolation=on"
   249	            )
   250	
   251	
   252	def _verify_pam_user_nested(records: Sequence[Any]) -> None:
   253	    seen_pam_user = False
   254	    for record in records:
   255	        if getattr(record, "resource_type", None) != "pamUser":
   256	            continue
   257	        seen_pam_user = True
   258	        payload = getattr(record, "payload", {}) or {}
   259	        if not payload.get("login"):
   260	            raise AssertionError(f"pamUser {record.title} has no login in discovered payload")
   261	    if not seen_pam_user:
   262	        raise AssertionError("nested pamUser record was not discovered")
