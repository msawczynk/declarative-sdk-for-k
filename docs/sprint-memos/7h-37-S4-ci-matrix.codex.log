   329	def get(name: str) -> ScenarioSpec:
   330	    """Look up a scenario by name; raise :class:`KeyError` if absent.
   331	
   332	    Names are the canonical Keeper resource types (``pamMachine`` etc.)
   333	    so the ``--scenario`` CLI flag reads naturally.
   334	    """
   335	    try:
   336	        return _SCENARIOS[name]
   337	    except KeyError as exc:
   338	        available = ", ".join(sorted(_SCENARIOS))
   339	        raise KeyError(f"unknown smoke scenario {name!r}; available: {available}") from exc
   340	
   341	
   342	def names() -> list[str]:
   343	    """Return all registered scenario names, sorted alphabetically."""
   344	    return sorted(_SCENARIOS)
   345	
   346	
   347	def all_scenarios() -> list[ScenarioSpec]:
   348	    """Return every registered scenario in name order."""
   349	    return [_SCENARIOS[name] for name in names()]

