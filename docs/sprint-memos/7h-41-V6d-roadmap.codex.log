    82	        raise SchemaError(
    83	            reason="document is a pam-environment manifest, not keeper-vault.v1",
    84	            next_action="use load_manifest() for PAM or fix top-level schema:",
    85	        )
    86	    if family != VAULT_FAMILY:
    87	        raise SchemaError(
    88	            reason=f"expected {VAULT_FAMILY!r}, got {family!r}",
    89	            next_action="set schema: keeper-vault.v1 on the manifest",
    90	        )
    91	    try:
    92	        return VaultManifestV1.model_validate(document)
    93	    except ValueError as exc:
    94	        raise SchemaError(
    95	            reason=str(exc),
    96	            next_action="fix records to match L1 rules in docs/VAULT_L1_DESIGN.md",
    97	        ) from exc

