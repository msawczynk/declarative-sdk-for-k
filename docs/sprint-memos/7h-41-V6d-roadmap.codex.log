   179	    def folder_match_strings(folder):   # type: (BaseFolderNode) -> collections.Iterable[str]
   180	        return filter(lambda f: isinstance(f, str) and len(f) > 0, [folder.name, folder.uid])
   181	
   182	    @staticmethod
   183	    def record_match_strings(record):     # type: (Record) -> collections.Iterable[str]
   184	        return filter(lambda f: isinstance(f, str) and len(f) > 0, [record.title, record.record_uid, record.login, record.login_url, record.notes])
   185	
   186	    @staticmethod
   187	    def chunk_list(l, n):
   188	        for i in range(0, len(l), n):
   189	            yield l[i:i + n]
   190	
   191	    def get_parser(self):
   192	        return ls_parser
