    26	
    27	    model_config = ConfigDict(extra="allow", populate_by_name=True, str_strip_whitespace=True)
    28	
    29	
    30	class VaultRecord(_VaultModel):
    31	    """One ``records[]`` entry (see ``keeper-vault.v1`` schema ``$defs.record``)."""
    32	
    33	    uid_ref: str
    34	    type: str
    35	    title: str
    36	    folder_ref: str | None = None
    37	    notes: str | None = None
    38	    fields: list[dict[str, Any]] = Field(default_factory=list)
    39	    custom: list[dict[str, Any]] = Field(default_factory=list)
    40	    keeper_uid: str | None = None
    41	
    42	
    43	class VaultManifestV1(_VaultModel):
    44	    """Top-level ``keeper-vault.v1`` manifest (slice 1).
    45	
    46	    JSON key remains ``schema`` (alias). Python attribute is ``vault_schema`` so
    47	    we do not shadow :meth:`pydantic.BaseModel.schema`.
    48	    """
    49	
    50	    vault_schema: Literal["keeper-vault.v1"] = Field(default=VAULT_FAMILY, alias="schema")
    51	    records: list[VaultRecord] = Field(default_factory=list)
    52	    record_types: list[dict[str, Any]] = Field(default_factory=list)
    53	    attachments: list[dict[str, Any]] = Field(default_factory=list)
    54	    keeper_fill: dict[str, Any] | None = None
    55	
    56	    @model_validator(mode="after")
    57	    def _l1_login_slice(self) -> VaultManifestV1:
    58	        """``docs/VAULT_L1_DESIGN.md`` §1 — L1 allows ``login`` records only."""
    59	        bad = [r.type for r in self.records if r.type != "login"]
    60	        if bad:
    61	            raise ValueError(
    62	                "keeper-vault L1 slice allows only records with type='login'; "
    63	                f"found other type(s): {sorted(set(bad))[:8]}"
    64	            )
    65	        return self
    66	
    67	    def iter_uid_refs(self) -> list[tuple[str, str]]:
    68	        """Return ``(uid_ref, record_type)`` for each record (graph prelude)."""
    69	        return [(r.uid_ref, r.type) for r in self.records]
    70	
    71	
    72	def load_vault_manifest(document: dict[str, Any]) -> VaultManifestV1:
    73	    """Validate with JSON Schema + semantic rules, then parse as :class:`VaultManifestV1`.
    74	
    75	    Raises :class:`SchemaError` if the document is not ``keeper-vault.v1`` or
    76	    fails validation / L1 slice rules.
