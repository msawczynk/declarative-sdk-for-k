   170	def _do(admin_params, command: str) -> str:
   171	    """Run a keeper CLI command via cli.do_command, capturing stdout.
   172	
   173	    Commander CLI subcommands print results directly to stdout (tabulate /
   174	    json.dump) and usually return None. We redirect stdout into a buffer so the
   175	    caller sees the actual payload and the terminal stays clean.
   176	    """
   177	    import contextlib
   178	    import io
   179	
   180	    from keepercommander import cli
   181	
   182	    log.info("CLI: %s", command)
   183	    buf = io.StringIO()
   184	    with contextlib.redirect_stdout(buf):
   185	        result = cli.do_command(admin_params, command)
   186	    captured = buf.getvalue()
   187	    if isinstance(result, str) and result:
   188	        return result
   189	    return captured
   190	
