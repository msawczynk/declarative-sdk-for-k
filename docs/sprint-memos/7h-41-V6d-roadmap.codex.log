    75	
    76	    @property
    77	    def title_prefix(self) -> str:
    78	        return self.profile.title_prefix
    79	
    80	
    81	def _default_context() -> SmokeRunContext:
    82	    return SmokeRunContext(profile=identity.DEFAULT_PROFILE)
    83	
    84	
    85	def _active_resources(context: SmokeRunContext | None = None) -> list[dict[str, Any]]:
    86	    if _ACTIVE_SCENARIO_FAMILY != PAM_FAMILY:
    87	        raise RuntimeError("active smoke scenario is not a PAM scenario")
    88	    run_context = context if context is not None else _default_context()
    89	    return _ACTIVE_SCENARIO.build_resources(PAM_CONFIG_UID_REF, run_context.title_prefix)
