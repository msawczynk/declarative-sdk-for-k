   155	def _raise_schema_error(errors: list[jsonschema.ValidationError]) -> None:
   156	    first = sorted(errors, key=lambda error: list(error.absolute_path))[0]
   157	    location = "/".join(str(part) for part in first.absolute_path) or "<root>"
   158	    raise SchemaError(
   159	        reason=f"manifest failed schema: {first.message}",
   160	        context={"location": location, "error_count": len(errors)},
   161	        next_action="fix the reported fields then re-run validation",
   162	    )
