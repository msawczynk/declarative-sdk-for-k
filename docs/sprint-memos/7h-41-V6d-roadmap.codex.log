     3	Canonical payload matches METADATA_OWNERSHIP.md:
     4	
     5	    {
     6	      "manager": "keeper-pam-declarative",
     7	      "version": "1",
     8	      "uid_ref": "pc.domain-local-admin",
     9	      "manifest": "acme-prod",
    10	      "resource_type": "pamUser",
    11	      "parent_uid_ref": null,
    12	      "first_applied_at": "2026-04-15T18:22:11Z",
    13	      "last_applied_at": "2026-04-16T02:05:44Z",
    14	      "applied_by": "commander/unknown"
    15	    }
    16	
    17	Stored as a JSON string in a custom record field labelled
    18	``keeper_declarative_manager`` (single-line text).
    19	"""
    20	
    21	from __future__ import annotations
    22	
    23	import datetime as _dt
    24	import json
    25	from typing import Any
    26	
    27	MANAGER_NAME = "keeper-pam-declarative"
    28	MARKER_VERSION = "1"
    29	MARKER_FIELD_LABEL = "keeper_declarative_manager"
    30	
    31	
    32	def encode_marker(
    33	    *,
    34	    uid_ref: str,
    35	    manifest: str,
    36	    resource_type: str,
    37	    parent_uid_ref: str | None = None,
    38	    first_applied_at: str | None = None,
    39	    last_applied_at: str | None = None,
    40	    applied_by: str = "commander/unknown",
    41	) -> dict[str, Any]:
    42	    now = _utc_now()
    43	    first_seen = first_applied_at or now
    44	    return {
    45	        "manager": MANAGER_NAME,
    46	        "version": MARKER_VERSION,
    47	        "uid_ref": uid_ref,
    48	        "manifest": manifest,
    49	        "resource_type": resource_type,
    50	        "parent_uid_ref": parent_uid_ref,
    51	        "first_applied_at": first_seen,
    52	        "last_applied_at": last_applied_at or first_seen,
    53	        "applied_by": applied_by,
    54	    }
    55	
    56	
    57	def serialize_marker(marker: dict[str, Any]) -> str:
    58	    return json.dumps(marker, separators=(",", ":"), sort_keys=True)
    59	
    60	
    61	def decode_marker(raw: str | None) -> dict[str, Any] | None:
    62	    if not raw:
    63	        return None
    64	    try:
    65	        data = json.loads(raw)
    66	    except (TypeError, ValueError):
    67	        return None
    68	    if not isinstance(data, dict):
    69	        return None
    70	    if data.get("manager") != MANAGER_NAME:
    71	        return data  # still return so diff can flag as foreign-managed
    72	    return data
    73	
    74	
    75	def utc_timestamp() -> str:
    76	    """Return the current UTC time as an ISO-8601 ``Z``-suffixed string.
    77	
    78	    The format matches what :func:`encode_marker` writes into
    79	    ``first_applied_at`` / ``last_applied_at``; exposed as a public
    80	    helper so providers can stamp ``last_applied_at`` without
    81	    round-tripping through :func:`encode_marker` just for the
    82	    timestamp.
    83	    """
    84	    return _dt.datetime.now(_dt.UTC).strftime("%Y-%m-%dT%H:%M:%SZ")
