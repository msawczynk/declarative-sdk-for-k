    74	def _folder_payload(live_folder: dict[str, Any]) -> dict[str, Any]:
    75	    nested = live_folder.get("payload")
    76	    if isinstance(nested, dict):
    77	        payload = dict(nested)
    78	        for key in ("uid_ref", "path", "parent_folder_uid_ref", "color"):
    79	            if key in live_folder and key not in payload:
    80	                payload[key] = live_folder[key]
    81	        return payload
    82	
    83	    payload = dict(live_folder)
    84	    for key in (
    85	        "keeper_uid",
    86	        "folder_uid",
    87	        "uid",
    88	        "resource_type",
    89	        "title",
    90	        "payload",
    91	        "marker",
    92	        "custom",
    93	        "custom_fields",
    94	    ):
    95	        payload.pop(key, None)
    96	    return payload
    97	
    98	
    99	def _folder_keeper_uid(live_folder: dict[str, Any]) -> str | None:
   100	    value = live_folder.get("keeper_uid") or live_folder.get("folder_uid") or live_folder.get("uid")
   101	    return str(value) if value else None
   102	
   103	
   104	def _folder_uid_ref(
   105	    payload: dict[str, Any],
   106	    marker: dict[str, Any] | None,
   107	) -> str | None:
   108	    value = payload.get("uid_ref") or (marker or {}).get("uid_ref")
   109	    return str(value) if value else None
   110	
   111	
   112	def _folder_path(payload: dict[str, Any]) -> str | None:
   113	    value = payload.get("path")
   114	    return str(value) if value else None
   115	
   116	
   117	def _folder_title(payload: dict[str, Any], uid_ref: str | None) -> str:
   118	    return _folder_path(payload) or str(payload.get("title") or uid_ref or "")
   119	
   120	
   121	def _desired_folder_payload(
   122	    payload: dict[str, Any],
   123	    *,
   124	    manifest_name: str,
   125	) -> dict[str, Any]:
   126	    out = dict(payload)
   127	    out["marker"] = encode_marker(
   128	        uid_ref=str(payload["uid_ref"]),
   129	        manifest=manifest_name,
   130	        resource_type=_SHARING_FOLDER_RESOURCE,
   131	        parent_uid_ref=payload.get("parent_folder_uid_ref"),
   132	    )
   133	    return out
   134	
   135	
   136	def _check_marker_supported(marker: dict[str, Any], *, uid_ref: str | None) -> None:
   137	    if marker.get("manager") != MANAGER_NAME:
   138	        return
   139	    if marker.get("version") not in (None, MARKER_VERSION):
   140	        raise OwnershipError(
   141	            reason=f"marker version {marker.get('version')} not supported by core v{MARKER_VERSION}",
   142	            uid_ref=uid_ref,
   143	            resource_type=_SHARING_FOLDER_RESOURCE,
   144	            next_action="upgrade the declarative core or rewrite the marker",
   145	        )
   146	
   147	
   148	def _folder_managed_by_manifest(
   149	    marker: dict[str, Any] | None,
   150	    *,
   151	    uid_ref: str | None,
   152	    manifest_name: str,
   153	) -> bool:
   154	    if not marker:
   155	        return False
   156	    _check_marker_supported(marker, uid_ref=uid_ref)
   157	    if marker.get("manager") != MANAGER_NAME:
   158	        return False
   159	    marker_manifest = marker.get("manifest")
   160	    return not marker_manifest or marker_manifest == manifest_name
   161	
   162	
   163	def _index_manifest_folders(manifest: SharingManifestV1) -> dict[str, dict[str, Any]]:
   164	    by_uid_ref: dict[str, dict[str, Any]] = {}
   165	    for folder in manifest.folders:
   166	        if folder.uid_ref in by_uid_ref:
   167	            raise ValueError(f"duplicate manifest folder uid_ref: {folder.uid_ref}")
   168	        by_uid_ref[folder.uid_ref] = folder.model_dump(mode="python", exclude_none=True)
   169	    return by_uid_ref
   170	
   171	
   172	def _index_live_folders(
   173	    live_folders: list[dict[str, Any]],
   174	) -> tuple[dict[str, _LiveFolder], dict[str, _LiveFolder], list[_LiveFolder]]:
   175	    by_uid_ref: dict[str, _LiveFolder] = {}
   176	    by_path: dict[str, _LiveFolder] = {}
   177	    indexed: list[_LiveFolder] = []
   178	    for index, live_folder in enumerate(live_folders):
   179	        payload = _folder_payload(live_folder)
   180	        marker = _folder_marker(live_folder)
   181	        uid_ref = _folder_uid_ref(payload, marker)
   182	        path = _folder_path(payload)
   183	        row = _LiveFolder(
   184	            index=index,
   185	            raw=live_folder,
   186	            payload=payload,
   187	            marker=marker,
   188	            keeper_uid=_folder_keeper_uid(live_folder),
   189	            uid_ref=uid_ref,
   190	            path=path,
   191	        )
   192	        indexed.append(row)
   193	        if uid_ref and uid_ref not in by_uid_ref:
   194	            by_uid_ref[uid_ref] = row
   195	        if path and path not in by_path:
   196	            by_path[path] = row
   197	    return by_uid_ref, by_path, indexed
   198	
   199	
   200	def _folder_diff_fields(live_payload: dict[str, Any], desired_payload: dict[str, Any]) -> list[str]:
   201	    changed: list[str] = []
   202	    for field in _FOLDER_DIFF_FIELDS:
   203	        if live_payload.get(field) != desired_payload.get(field):
   204	            changed.append(field)
   205	    return changed
   206	
   207	
   208	def _compute_folders_changes(
   209	    manifest: SharingManifestV1,
   210	    live_folders: list[dict[str, Any]],
   211	    *,
   212	    manifest_name: str = "vault-sharing",
   213	    allow_delete: bool = False,
   214	) -> list[Change]:
   215	    desired_by_uid_ref = _index_manifest_folders(manifest)
   216	    live_by_uid_ref, live_by_path, indexed_live = _index_live_folders(live_folders)
   217	
   218	    changes: list[Change] = []
   219	    matched: set[int] = set()
   220	
   221	    for uid_ref, desired_payload in desired_by_uid_ref.items():
   222	        path = _folder_path(desired_payload)
   223	        live = live_by_uid_ref.get(uid_ref) or (live_by_path.get(path) if path else None)
   224	        title = _folder_title(desired_payload, uid_ref)
   225	        if live is None:
   226	            changes.append(
   227	                Change(
   228	                    kind=ChangeKind.ADD,
   229	                    uid_ref=uid_ref,
   230	                    resource_type=_SHARING_FOLDER_RESOURCE,
   231	                    title=title,
   232	                    after=_desired_folder_payload(
   233	                        desired_payload,
   234	                        manifest_name=manifest_name,
   235	                    ),
   236	                    manifest_name=manifest_name,
   237	                )
   238	            )
   239	            continue
   240	
   241	        matched.add(live.index)
   242	        if not _folder_managed_by_manifest(
   243	            live.marker,
   244	            uid_ref=live.uid_ref,
   245	            manifest_name=manifest_name,
   246	        ):
   247	            changes.append(
   248	                Change(
   249	                    kind=ChangeKind.SKIP,
   250	                    uid_ref=uid_ref,
   251	                    resource_type=_SHARING_FOLDER_RESOURCE,
   252	                    title=title,
   253	                    keeper_uid=live.keeper_uid,
   254	                    before=live.payload,
   255	                    reason="unmanaged folder",
   256	                    manifest_name=manifest_name,
   257	                )
   258	            )
   259	            continue
   260	
   261	        diff_fields = _folder_diff_fields(live.payload, desired_payload)
   262	        if diff_fields:
   263	            changes.append(
   264	                Change(
   265	                    kind=ChangeKind.UPDATE,
   266	                    uid_ref=uid_ref,
   267	                    resource_type=_SHARING_FOLDER_RESOURCE,
   268	                    title=title,
   269	                    keeper_uid=live.keeper_uid,
   270	                    before={field: live.payload.get(field) for field in diff_fields},
   271	                    after={field: desired_payload.get(field) for field in diff_fields},
   272	                    manifest_name=manifest_name,
   273	                )
   274	            )
   275	
   276	    for live in indexed_live:
   277	        if live.index in matched:
   278	            continue
   279	        orphan_uid_ref = live.uid_ref or _folder_path(live.payload)
   280	        title = _folder_title(live.payload, orphan_uid_ref)
   281	        if not _folder_managed_by_manifest(
   282	            live.marker,
   283	            uid_ref=orphan_uid_ref,
   284	            manifest_name=manifest_name,
   285	        ):
   286	            changes.append(
   287	                Change(
   288	                    kind=ChangeKind.SKIP,
   289	                    uid_ref=orphan_uid_ref,
   290	                    resource_type=_SHARING_FOLDER_RESOURCE,
   291	                    title=title,
   292	                    keeper_uid=live.keeper_uid,
   293	                    before=live.payload,
   294	                    reason="unmanaged folder",
   295	                    manifest_name=manifest_name,
   296	                )
   297	            )
   298	            continue
   299	        if allow_delete:
   300	            changes.append(
   301	                Change(
   302	                    kind=ChangeKind.DELETE,
   303	                    uid_ref=orphan_uid_ref,
   304	                    resource_type=_SHARING_FOLDER_RESOURCE,
   305	                    title=title,
   306	                    keeper_uid=live.keeper_uid,
   307	                    before=live.payload,
   308	                    manifest_name=manifest_name,
   309	                )
   310	            )
   311	            continue
   312	        changes.append(
   313	            Change(
   314	                kind=ChangeKind.SKIP,
   315	                uid_ref=orphan_uid_ref,
   316	                resource_type=_SHARING_FOLDER_RESOURCE,
   317	                title=title,
   318	                keeper_uid=live.keeper_uid,
   319	                before=live.payload,
   320	                reason="managed folder missing from manifest; pass --allow-delete to remove",
   321	                manifest_name=manifest_name,
   322	            )
   323	        )
   324	
   325	    return changes
   326	
   327	
   328	def compute_sharing_diff(
   329	    manifest: SharingManifestV1,
   330	    live_folders: list[dict[str, Any]] | None = None,
   331	    *,
   332	    manifest_name: str = "vault-sharing",
   333	    allow_delete: bool = False,
   334	    live_shared_folders: list[dict[str, Any]] | None = None,
   335	    live_share_records: list[dict[str, Any]] | None = None,
   336	    live_share_folders: list[dict[str, Any]] | None = None,
   337	) -> list[Change]:
   338	    """Classify sharing manifest state vs provider rows.
   339	
   340	    Only ``folders[]`` is implemented in this slice. Passing any future block's
   341	    live rows raises so callers do not mistake schema coverage for diff/apply
   342	    coverage.
   343	    """
   344	
   345	    if live_shared_folders is not None:
   346	        raise NotImplementedError("shared_folders[] diff is deferred to 7h-41")
   347	    if live_share_records is not None:
   348	        raise NotImplementedError("share_records[] diff is deferred to 7h-41")
   349	    if live_share_folders is not None:
   350	        raise NotImplementedError("share_folders[] diff is deferred to 7h-41")
   351	    if live_folders is not None:
   352	        return _compute_folders_changes(
   353	            manifest,
   354	            live_folders,
   355	            manifest_name=manifest_name,
   356	            allow_delete=allow_delete,
   357	        )
   358	    return []
   359	
   360	
   361	__all__ = [
   362	    "_SHARING_FOLDER_RESOURCE",
   363	    "_compute_folders_changes",
   364	    "compute_sharing_diff",
   365	]

