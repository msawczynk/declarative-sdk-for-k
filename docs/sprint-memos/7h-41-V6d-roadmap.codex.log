   176	    errors = list(validator.iter_errors(document))
   177	    if errors:
   178	        _raise_schema_error(errors)
   179	
   180	    uid_refs = _iter_uid_refs(document)
   181	    duplicates = sorted({uid_ref for uid_ref in uid_refs if uid_refs.count(uid_ref) > 1})
   182	    if duplicates:
   183	        raise SchemaError(
   184	            reason=f"duplicate uid_ref values: {duplicates}",
   185	            next_action="rename duplicates so every uid_ref is unique",
   186	        )
