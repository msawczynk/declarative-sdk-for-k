   165	def _iter_uid_refs(document: dict[str, Any]) -> list[str]:
   166	    refs: list[str] = []
   167	    for collection in ("folders", "shared_folders", "share_records", "share_folders"):
   168	        for item in document.get(collection) or []:
   169	            if isinstance(item, dict) and isinstance(item.get("uid_ref"), str):
   170	                refs.append(item["uid_ref"])
   171	    return refs
