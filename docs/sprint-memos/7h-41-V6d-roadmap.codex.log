    49	def resolve_manifest_family(document: dict[str, Any]) -> str:
    50	    """Return the manifest family key (e.g. ``pam-environment.v1``).
    51	
    52	    New families declare ``schema: "<family>.v1"``. Legacy PAM manifests omit
    53	    ``schema`` and use ``version: "1"`` plus ``name``.
    54	    """
    55	    raw = document.get("schema")
    56	    if isinstance(raw, str) and raw.strip():
    57	        key = raw.strip()
    58	        if key not in SCHEMA_RESOURCE_BY_FAMILY:
    59	            known = ", ".join(sorted(SCHEMA_RESOURCE_BY_FAMILY))
    60	            raise SchemaError(
    61	                reason=f"unknown manifest schema {key!r}",
    62	                next_action=f"use a packaged family key: {known}",
    63	            )
    64	        return key
    65	
    66	    if document.get("version") == "1" and isinstance(document.get("name"), str):
    67	        name = document.get("name")
    68	        assert isinstance(name, str)
    69	        if name.strip():
    70	            return PAM_FAMILY
    71	
    72	    raise SchemaError(
    73	        reason="manifest must declare schema: <family>.v1 or legacy PAM fields version+name",
    74	        next_action=(
    75	            "for PAM examples use version: '1' and name: ...; for other families set "
    76	            "schema: keeper-vault.v1 (etc.)"
    77	        ),
    78	    )
    79	
    80	
    81	def _read_packaged_schema_bytes(family: str) -> str:
    82	    rel = SCHEMA_RESOURCE_BY_FAMILY[family]
    83	    try:
    84	        root = resources.files("keeper_sdk.core.schemas")
    85	    except (FileNotFoundError, ModuleNotFoundError, AttributeError, OSError, TypeError) as exc:
    86	        raise SchemaError(
    87	            reason=f"packaged schema namespace unavailable for {family}",
    88	            next_action="reinstall keeper_sdk or report a packaging bug",
    89	        ) from exc
    90	    node = root.joinpath(rel)
    91	    try:
    92	        return node.read_text(encoding="utf-8")
    93	    except (FileNotFoundError, OSError) as exc:
    94	        raise SchemaError(
    95	            reason=f"packaged schema not found for {family} ({rel})",
    96	            next_action="reinstall keeper_sdk or report a packaging bug",
    97	        ) from exc
