    99	
   100	def _read_pam_schema_from_sibling_or_env() -> dict[str, Any] | None:
   101	    """Legacy fallbacks for ``pam-environment.v1`` only (dev trees without wheel)."""
   102	    import os
   103	
   104	    here = Path(__file__).resolve()
   105	    for parent in here.parents:
   106	        candidate = parent.parent / "keeper-pam-declarative" / "manifests" / PAM_SCHEMA_FILENAME
   107	        if candidate.is_file():
   108	            return json.loads(candidate.read_text(encoding="utf-8"))
   109	        candidate2 = parent / "keeper-pam-declarative" / "manifests" / PAM_SCHEMA_FILENAME
   110	        if candidate2.is_file():
   111	            return json.loads(candidate2.read_text(encoding="utf-8"))
   112	
   113	    override = os.environ.get("KEEPER_DECLARATIVE_SCHEMA")
   114	    if override:
   115	        return json.loads(Path(override).read_text(encoding="utf-8"))
   116	    return None
   117	
   118	
   119	@lru_cache(maxsize=len(SCHEMA_RESOURCE_BY_FAMILY))
   120	def load_schema_for_family(family: str) -> dict[str, Any]:
   121	    """Load the packaged JSON Schema dict for *family* (const matches ``schema:``)."""
   122	    if family not in SCHEMA_RESOURCE_BY_FAMILY:
   123	        raise SchemaError(
   124	            reason=f"unknown schema family {family!r}",
   125	            next_action="use resolve_manifest_family or SCHEMA_RESOURCE_BY_FAMILY keys",
