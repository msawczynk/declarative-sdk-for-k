   194	    def execute(self, params, **kwargs):
   195	        show_folders = kwargs.get('folders_only') is True
   196	        show_records = kwargs.get('records_only') is True
   197	        show_detail = kwargs['detail'] if 'detail' in kwargs else False
   198	        if not show_folders and not show_records:
   199	            show_folders = True
   200	            show_records = True
   201	        fmt = kwargs.get('format') or ''
   202	        if fmt in ('json', 'csv'):
   203	            show_detail = True
   204	
   205	        folder = params.folder_cache[params.current_folder] if params.current_folder in params.folder_cache else params.root_folder
   206	        pattern = kwargs['pattern'] if 'pattern' in kwargs else None
   207	        if pattern:
   208	            rs = try_resolve_path(params, kwargs['pattern'])
   209	            if rs is not None:
   210	                folder, pattern = rs
   211	
   212	        regex = None
   213	        if pattern:
   214	            regex = re.compile(fnmatch.translate(pattern), re.IGNORECASE).match
   215	
   216	        folders = []    # type: List[BaseFolderNode]
   217	        records = []    # type: List[vault.KeeperRecord]
   218	
   219	        recursive_search = kwargs.get('recursive')
