    60	@dataclass(frozen=True)
    61	class SmokeRunContext:
    62	    """Run-scoped profile metadata.
    63	
    64	    ``node_uid`` is smoke-side metadata only. The SDK CLI does not have
    65	    ``dsk plan/apply --node`` support yet, so this runner deliberately does not
    66	    forward it to SDK subprocesses.
