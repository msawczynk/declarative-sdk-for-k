    21	PAM_FAMILY = "pam-environment.v1"
    22	SHARING_FAMILY = "keeper-vault-sharing.v1"
    23	PAM_SCHEMA_FILENAME = "pam-environment.v1.schema.json"
    24	
    25	# Canonical registry: manifest ``schema:`` const -> path under keeper_sdk.core.schemas
    26	SCHEMA_RESOURCE_BY_FAMILY: dict[str, str] = {
    27	    PAM_FAMILY: PAM_SCHEMA_FILENAME,
    28	    "keeper-enterprise.v1": "keeper-enterprise/keeper-enterprise.v1.schema.json",
    29	    "keeper-epm.v1": "keeper-epm/keeper-epm.v1.schema.json",
    30	    "keeper-integrations-events.v1": (
    31	        "keeper-integrations-events/keeper-integrations-events.v1.schema.json"
    32	    ),
    33	    "keeper-integrations-identity.v1": (
    34	        "keeper-integrations-identity/keeper-integrations-identity.v1.schema.json"
    35	    ),
    36	    "keeper-ksm.v1": "keeper-ksm/keeper-ksm.v1.schema.json",
    37	    "keeper-pam-extended.v1": "keeper-pam-extended/keeper-pam-extended.v1.schema.json",
    38	    "keeper-security-posture.v1": (
    39	        "keeper-security-posture/keeper-security-posture.v1.schema.json"
    40	    ),
    41	    SHARING_FAMILY: "keeper-vault-sharing/keeper-vault-sharing.v1.schema.json",
    42	    "keeper-vault.v1": "keeper-vault/keeper-vault.v1.schema.json",
    43	}
    44	
    45	# Backward-compat alias used by older imports / docs.
    46	SCHEMA_ID = PAM_SCHEMA_FILENAME
