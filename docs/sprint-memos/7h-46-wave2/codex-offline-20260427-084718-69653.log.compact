+def _latest_session_boot_time() -> float | None:
+    """Return the latest session boot timestamp, preferring the log header."""
+    logs = sorted(HOOK_LOG_DIR.glob("session-boot-*.log")) if HOOK_LOG_DIR.exists() else []
+    if not logs:
+        return None
+    boot = logs[-1]
+    try:
+        first = boot.read_text(encoding="utf-8", errors="replace").splitlines()[0]
+        m = BOOT_HEADER_RE.search(first)
+        if m:
+            return datetime.fromisoformat(m.group(1).replace("Z", "+00:00")).timestamp()
+    except (OSError, IndexError, ValueError):
+        pass
+    try:
+        return boot.stat().st_mtime
+    except OSError:
+        return None
+
+
+def _marker_state(marker: Path) -> str:
+    try:
+        for line in marker.read_text(encoding="utf-8", errors="replace").splitlines():
+            key, sep, value = line.partition("=")
+            if sep and key == "STATE":
+                return value.strip().split()[0] if value.strip() else "UNKNOWN"
+    except OSError:
+        pass
+    return "UNKNOWN"
+
+
+def _codex_worker_counts(boot_time: float, marker_dir: Path = Path("/tmp")) -> dict[str, int]:
+    """Count Codex worker marker files touched during this session."""
+    counts = {
+        "codex_workers_session": 0,
+        "codex_workers_done": 0,
+        "codex_workers_launched": 0,
+    }
+    for pattern in CODEX_MARKER_PATTERNS:
+        for marker in marker_dir.glob(pattern):
+            try:
+                if marker.stat().st_mtime < boot_time:
+                    continue
+            except OSError:
+                continue
+            state = _marker_state(marker)
+            counts["codex_workers_session"] += 1
+            if state == "DONE":
+                counts["codex_workers_done"] += 1
+            elif state in {"LAUNCHED", "RUNNING"}:
+                counts["codex_workers_launched"] += 1
+    return counts
+
+
 def _read_transcript(transcript: Path, max_messages: int = 1000):
     """Yield (role, text) tuples from the transcript."""
     if not transcript.exists():
