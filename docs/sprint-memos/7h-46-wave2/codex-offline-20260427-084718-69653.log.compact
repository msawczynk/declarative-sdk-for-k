@@ -0,0 +1,37 @@
+#!/usr/bin/env python3
+"""Offline tests for Codex marker telemetry in agent_review_loop.py."""
+import importlib.util
+import os
+import tempfile
+from pathlib import Path
+
+script = Path(__file__).resolve().parent / "agent_review_loop.py"
+spec = importlib.util.spec_from_file_location("agent_review_loop", script)
+mod = importlib.util.module_from_spec(spec)
+spec.loader.exec_module(mod)
+
+
+def write_marker(root: Path, name: str, text: str, mtime: float) -> Path:
+    marker = root / name
+    marker.write_text(text, encoding="utf-8")
+    os.utime(marker, (mtime, mtime))
+    return marker
+
+
+with tempfile.TemporaryDirectory() as td:
+    root = Path(td)
+    boot = 1000.0
+
+    write_marker(root, "codex-offline-old.marker", "STATE=DONE\nEXIT_CODE=0\n", 900.0)
+    write_marker(root, "codex-offline-done.marker", "STATE=DONE EXIT_CODE=0\n", 1001.0)
+    write_marker(root, "codex-offline-launched.marker", "STATE=LAUNCHED\n", 1002.0)
+    write_marker(root, "codex-live-running.marker", "STATE=RUNNING\n", 1003.0)
+    write_marker(root, "codex-offline-malformed.marker", "TS=20260427-010101\n", 1004.0)
+
+    counts = mod._codex_worker_counts(boot_time=boot, marker_dir=root)
+
+assert counts["codex_workers_session"] == 4, "new offline/live/malformed markers count as session workers; old marker does not"
+assert counts["codex_workers_done"] == 1, "new DONE marker counts as done; old DONE marker does not"
+assert counts["codex_workers_launched"] == 2, "new LAUNCHED/RUNNING markers count as launched"
+
+print("OK: _codex_worker_counts all 5 cases pass")

