+#!/usr/bin/env bash
+# Smoke test for codex_wave_launcher.sh.
+
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+LAUNCHER="$SCRIPT_DIR/codex_wave_launcher.sh"
+
+fail() {
+  echo "test_codex_wave_launcher: $*" >&2
+  exit 1
+}
+
+wait_for_file() {
+  local path="$1"
+  local i=0
+  for i in $(seq 1 50); do
+    if [[ -f "$path" ]]; then
+      return 0
+    fi
+    sleep 0.1
+  done
+  return 1
+}
+
+wait_for_nonempty() {
+  local path="$1"
+  local i=0
+  for i in $(seq 1 50); do
+    if [[ -s "$path" ]]; then
+      return 0
+    fi
+    sleep 0.1
+  done
+  return 1
+}
+
+wait_for_marker_done() {
+  local marker="$1"
+  local i=0
+  for i in $(seq 1 50); do
+    if grep -q '^STATE=DONE' "$marker" 2>/dev/null; then
+      return 0
+    fi
+    sleep 0.1
+  done
+  return 1
+}
+
+field_for_worker() {
+  local output="$1"
+  local worker_id="$2"
+  local field="$3"
+
+  printf '%s\n' "$output" | awk -v worker_id="$worker_id" -v field="$field" '
+    $1 == "LAUNCHED" && $2 == worker_id {
+      for (i = 3; i <= NF; i++) {
+        if (index($i, field "=") == 1) {
+          sub("^" field "=", "", $i)
+          print $i
+          exit
+        }
+      }
+    }
+  '
+}
+
+TMP_ROOT="$(mktemp -d "${TMPDIR:-/tmp}/codex-wave-test.XXXXXX")"
+cleanup() {
+  rm -rf "$TMP_ROOT"
+}
+trap cleanup EXIT
+
+# codex_resolve_bin.sh honors CODEX_BIN. Use a tiny stub instead of a real
+# Codex CLI process so the smoke test only exercises dispatch mechanics.
+FAKE_CODEX="$TMP_ROOT/fake-codex"
+cat >"$FAKE_CODEX" <<'SH'
+#!/usr/bin/env bash
+echo "FAKE_CODEX cwd=$PWD"
+printf 'ARGS:'
+for arg in "$@"; do
+  printf ' <%s>' "$arg"
+done
+printf '\n'
+SH
+chmod +x "$FAKE_CODEX"
+
+PROMPT_A="$TMP_ROOT/offline.md"
+PROMPT_B="$TMP_ROOT/live.md"
+MANIFEST="$TMP_ROOT/wave.yaml"
+HELPER="$TMP_ROOT/login-helper"
+
+printf 'offline smoke prompt\n' >"$PROMPT_A"
+printf 'live smoke prompt\n' >"$PROMPT_B"
+touch "$HELPER"
+
+cat >"$MANIFEST" <<YAML
+wave: "smoke-wave"
+workers:
+  - id: "A"
+    prompt: "$PROMPT_A"
+    cwd: "$TMP_ROOT"
+    mode: "offline"
+  - id: "B"
+    prompt: "$PROMPT_B"
+    cwd: "$TMP_ROOT"
+    mode: "live"
+YAML
+
+OUTPUT="$(
+  CODEX_BIN="$FAKE_CODEX" \
+  CODEX_BIN_OVERRIDE="$FAKE_CODEX" \
+  KEEPER_SDK_LOGIN_HELPER="$HELPER" \
+  bash "$LAUNCHER" "$MANIFEST"
+)"
+
+LINE_COUNT="$(printf '%s\n' "$OUTPUT" | awk '/^LAUNCHED / { n++ } END { print n + 0 }')"
+[[ "$LINE_COUNT" -eq 2 ]] || fail "expected 2 LAUNCHED lines, got $LINE_COUNT: $OUTPUT"
+
+OFFLINE_LOG="$(field_for_worker "$OUTPUT" A log)"
+OFFLINE_MARKER="$(field_for_worker "$OUTPUT" A marker)"
+LIVE_LOG="$(field_for_worker "$OUTPUT" B log)"
+LIVE_MARKER="$(field_for_worker "$OUTPUT" B marker)"
+
+[[ -n "$OFFLINE_LOG" ]] || fail "missing offline log in output: $OUTPUT"
+[[ -n "$OFFLINE_MARKER" ]] || fail "missing offline marker in output: $OUTPUT"
+[[ -n "$LIVE_LOG" ]] || fail "missing live log in output: $OUTPUT"
+[[ "$LIVE_MARKER" == "n/a" ]] || fail "expected live marker=n/a, got $LIVE_MARKER"
+
+wait_for_file "$OFFLINE_LOG" || fail "offline log not created: $OFFLINE_LOG"
+wait_for_marker_done "$OFFLINE_MARKER" || fail "offline marker not completed: $OFFLINE_MARKER"
+wait_for_nonempty "$OFFLINE_LOG" || fail "offline log empty: $OFFLINE_LOG"
+
+wait_for_file "$LIVE_LOG" || fail "live log not created: $LIVE_LOG"
+wait_for_nonempty "$LIVE_LOG" || fail "live log empty: $LIVE_LOG"
+
+echo "PASS codex_wave_launcher smoke"

