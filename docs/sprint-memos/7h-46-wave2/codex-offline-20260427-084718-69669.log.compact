# Hard requirements
1. NEW `~/.cursor-daybook-sync/scripts/codex_wave_launcher.sh`:
   - Usage: `codex_wave_launcher.sh <wave-manifest.yaml>`.
   - Manifest schema (yaml):
     ```yaml
+while IFS=$'\t' read -r kind a b c d; do
+  case "$kind" in
+    W)
+      WAVE="$(decode_b64 "$a")"
+      ;;
+    R)
+      WORKER_COUNT=$((WORKER_COUNT + 1))
+      id="$(decode_b64 "$a")"
+      prompt="$(decode_b64 "$b")"
+      cwd="$(decode_b64 "$c")"
+      mode="$(decode_b64 "$d")"
+
+      if ! validate_worker_paths "$id" "$prompt" "$cwd"; then
+        FAILURES=$((FAILURES + 1))
+        continue
+      fi
+
+      case "$mode" in
+        offline|readonly)
+          if ! launch_offline "$id" "$prompt" "$cwd" "$mode"; then
+            FAILURES=$((FAILURES + 1))
+          fi
+          ;;
+        live)
+          if ! launch_live "$id" "$prompt" "$cwd" "$WAVE"; then
+            FAILURES=$((FAILURES + 1))
+          fi
+          ;;
+        *)
+          echo "codex_wave_launcher: worker $id unsupported mode: $mode" >&2
+          FAILURES=$((FAILURES + 1))
+          ;;
+      esac
+      ;;
+    "")
+      ;;
+    *)
+      echo "codex_wave_launcher: internal parser emitted unknown record kind: $kind" >&2
+      FAILURES=$((FAILURES + 1))
+      ;;
+  esac
+done <"$RECORDS_FILE"
+
+if [[ -z "$WAVE" || "$WORKER_COUNT" -eq 0 ]]; then
+  echo "codex_wave_launcher: manifest produced no launchable workers" >&2
+  exit 2
+fi
+
+if [[ "$FAILURES" -ne 0 ]]; then
+  exit 1
+fi
+exit 0
