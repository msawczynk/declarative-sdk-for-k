   146	def audit_tokens(transcript: Path | None) -> dict:
   147	    out: dict = {"transcript": str(transcript) if transcript else None}
   148	    if not transcript:
   149	        return out
   150	
   151	    user_chars = 0
   152	    assistant_chars = 0
   153	    assistant_words = 0
   154	    prose_hits = 0
   155	    prose_bursts = 0
   156	    bullet_lines = 0
   157	    plain_lines = 0
   158	    lesson_tag_refs = set()
   159	
   160	    for role, text in _read_transcript(transcript):
   161	        if role == "user":
   162	            user_chars += len(text)
   163	        elif role == "assistant":
   164	            assistant_chars += len(text)
   165	            prose_text = strip_code(text)
   166	            words = WORD_RE.findall(prose_text)
   167	            assistant_words += len(words)
   168	            prose_hits += sum(1 for w in words if PROSE_TOKENS.fullmatch(w))
   169	            prose_bursts += len(PROSE_BURST_RE.findall(prose_text))
   170	            for line in text.splitlines():
   171	                s = line.strip()
   172	                if not s:
   173	                    continue
   174	                if s.startswith(("-", "*", "1.", "2.", "3.", "#", "|", "```", "`")):
   175	                    bullet_lines += 1
   176	                else:
   177	                    plain_lines += 1
   178	            for m in LESSON_TAG_RE.findall(text):
   179	                lesson_tag_refs.add(m)
   180	
   181	    prose_density = (prose_hits / assistant_words * 100.0) if assistant_words else 0.0
   182	    bullet_ratio = (bullet_lines / max(bullet_lines + plain_lines, 1))
   183	
   184	    out.update({
   185	        "user_chars": user_chars,
   186	        "assistant_chars": assistant_chars,
