   293	    elif pd >= PROSE_DENSITY_WARN:
   294	        recs.append(f"prose: density {pd}% > {PROSE_DENSITY_WARN}%. Audit longest assistant messages; convert to bullets.")
   295	
   296	    bursts = tokens.get("prose_bursts", 0)
   297	    if bursts > 30:
