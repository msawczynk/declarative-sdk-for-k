   170	    sandbox_config: sandbox.SandboxConfig,
   171	    project_name: str,
   172	) -> dict[str, object]:
   173	    return {
   174	        "pid": os.getpid(),
   175	        "started_at": _utc_now_iso(),
   176	        "tenant_fqdn": tenant_fqdn,
   177	        "profile_id": str(profile.id),
   178	        "admin_commander_config": str(_physical_path(profile.admin_commander_config)),
   179	        "sf_title": sandbox_config.sf_title,
