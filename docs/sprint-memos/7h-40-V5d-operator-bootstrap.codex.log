    91	def _semver_tuple_at_least(installed: tuple[int, ...], minimum: tuple[int, ...]) -> bool:
    92	    span = max(len(installed), len(minimum))
    93	    for i in range(span):
    94	        a = installed[i] if i < len(installed) else 0
    95	        b = minimum[i] if i < len(minimum) else 0
    96	        if a > b:
    97	            return True
    98	        if a < b:
    99	            return False
