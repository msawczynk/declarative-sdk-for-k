   643	            "(KEEPER_EMAIL/KEEPER_PASSWORD/KEEPER_TOTP_SECRET; "
   644	            "KEEPER_SDK_LOGIN_HELPER unset)"
   645	        )
   646	    if login_helper == "deploy_watcher":
   647	        suffix = f" ({helper_path})" if helper_path else ""
   648	        return f"sdk auth path: deploy_watcher helper path via KEEPER_SDK_LOGIN_HELPER{suffix}"
   649	    raise ValueError(f"unknown login helper: {login_helper}")
