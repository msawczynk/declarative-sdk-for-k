   644	def sdktest_keeper_args(profile: SmokeProfile | None = None) -> list[str]:
   645	    """Return the argv prefix for invoking the keeper CLI as the profile user:
   646	       ['keeper', '--config', '<profile commander config>', '--batch-mode']
   647	    Caller appends subcommand + args.
   648	    """
   649	    smoke_profile = _profile_or_default(profile)
   650	    return ["keeper", "--config", str(smoke_profile.sdktest_commander_config), "--batch-mode"]
