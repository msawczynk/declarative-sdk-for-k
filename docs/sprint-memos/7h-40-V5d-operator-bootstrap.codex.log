   652	def _tail_text(text: str | None, *, max_lines: int = SDK_OUTPUT_TAIL_LINES) -> str:
   653	    if not text:
   654	        return "<empty>"
   655	    lines = text.splitlines()
   656	    omitted = max(0, len(lines) - max_lines)
   657	    tail = "\n".join(lines[-max_lines:])
   658	    if omitted:
   659	        return f"... ({omitted} line(s) omitted)\n{tail}"
   660	    return tail
