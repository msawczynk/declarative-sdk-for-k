   185	def _read_lock(path: Path) -> tuple[LockInfo, datetime]:
   186	    try:
   187	        raw = json.loads(path.read_text(encoding="utf-8"))
   188	    except json.JSONDecodeError as exc:
   189	        raise GuardError(f"corrupt lock {path}: invalid JSON") from exc
   190	    except FileNotFoundError:
   191	        raise
   192	    except OSError as exc:
   193	        raise GuardError(f"could not read smoke lock {path}: {exc}") from exc
   194	
   195	    if not isinstance(raw, dict):
   196	        raise GuardError(f"corrupt lock {path}: expected JSON object")
   197	    info = _lock_info_from_mapping(raw, path=path)
   198	    started_at = _parse_started_at(info.started_at, path=path)
   199	    return info, started_at
   200	
   201	
   202	def _lock_info_from_mapping(raw: dict[str, Any], *, path: Path) -> LockInfo:
   203	    required = {
   204	        "pid",
   205	        "started_at",
   206	        "tenant_fqdn",
   207	        "profile_id",
   208	        "admin_commander_config",
   209	        "sf_title",
   210	        "ksm_app_name",
   211	        "project_name",
   212	    }
   213	    missing = sorted(required - raw.keys())
   214	    if missing:
   215	        raise GuardError(f"corrupt lock {path}: missing {', '.join(missing)}")
   216	
   217	    pid = raw["pid"]
   218	    if not isinstance(pid, int) or isinstance(pid, bool) or pid <= 0:
   219	        raise GuardError(f"corrupt lock {path}: pid must be a positive integer")
   220	    string_fields: dict[str, str] = {}
   221	    for field in required - {"pid"}:
   222	        value = raw[field]
   223	        if not isinstance(value, str) or not value:
   224	            raise GuardError(f"corrupt lock {path}: {field} must be a non-empty string")
   225	        string_fields[field] = value
   226	
   227	    return LockInfo(
   228	        pid=pid,
   229	        started_at=string_fields["started_at"],
   230	        tenant_fqdn=string_fields["tenant_fqdn"],
   231	        profile_id=string_fields["profile_id"],
   232	        admin_commander_config=string_fields["admin_commander_config"],
   233	        sf_title=string_fields["sf_title"],
   234	        ksm_app_name=string_fields["ksm_app_name"],
   235	        project_name=string_fields["project_name"],
   236	    )
   237	
   238	
   239	def _parse_started_at(value: str, *, path: Path) -> datetime:
   240	    normalized = value[:-1] + "+00:00" if value.endswith("Z") else value
   241	    try:
   242	        parsed = datetime.fromisoformat(normalized)
   243	    except ValueError as exc:
   244	        raise GuardError(f"corrupt lock {path}: invalid started_at {value!r}") from exc
   245	    if parsed.tzinfo is None:
   246	        parsed = parsed.replace(tzinfo=UTC)
   247	    return parsed.astimezone(UTC)
   248	
   249	
   250	def _remove_stale_lock(path: Path, info: LockInfo) -> None:
   251	    try:
   252	        path.unlink()
   253	    except FileNotFoundError:
   254	        return
   255	    except OSError as exc:
   256	        raise GuardError(f"could not remove stale smoke lock {path}: {exc}") from exc
   257	    log.warning("removed stale smoke lock %s for dead pid %s", path, info.pid)
   258	
   259	
   260	def _pid_alive(pid: int) -> bool:
   261	    try:
   262	        os.kill(pid, 0)
   263	    except OSError:
   264	        return False
   265	    return True
   266	
   267	
   268	def _physical_path(value: str | Path) -> Path:
   269	    return Path(value).expanduser().resolve()
   270	
   271	
   272	def _safe_tenant_fqdn(tenant_fqdn: str) -> str:
   273	    safe = re.sub(r"[^A-Za-z0-9-]", "_", tenant_fqdn)
   274	    return safe or "unknown"
   275	
   276	
   277	def _safe_profile_id(profile_id: str) -> str:
   278	    safe = re.sub(r"[^A-Za-z0-9-]", "_", profile_id)
   279	    return safe or "unknown"
