   162	    tenant_safe = _safe_tenant_fqdn(tenant_fqdn)
   163	    profile_safe = _safe_profile_id(profile_id)
   164	    return lock_dir() / f".dsk-smoke-{tenant_safe}-{profile_safe}.lock"
