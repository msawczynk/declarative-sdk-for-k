   708	def _share_ksm_app_folder(
   709	    admin_params: Any,
   710	    *,
   711	    app_uid: str,
   712	    folder_uid: str,
   713	    profile: identity.SmokeProfile | None = None,
   714	) -> None:
   715	    smoke_profile = profile if profile is not None else identity.DEFAULT_PROFILE
   716	    config_path = str(smoke_profile.admin_commander_config)
   717	    env = dict(os.environ)
   718	    password = getattr(admin_params, "password", None) or _load_admin_password(smoke_profile)
   719	    env["KEEPER_PASSWORD"] = password
   720	    cmd = [
   721	        "keeper",
   722	        "--config",
   723	        config_path,
   724	        "--batch-mode",
   725	        "secrets-manager",
   726	        "share",
   727	        "add",
   728	        "--app",
   729	        app_uid,
   730	        "--secret",
   731	        folder_uid,
   732	        "--editable",
   733	    ]
   734	    result = subprocess.run(
   735	        cmd,
   736	        cwd=ROOT,
   737	        env=env,
   738	        check=False,
   739	        capture_output=True,
   740	        text=True,
   741	        stdin=subprocess.DEVNULL,
   742	    )
   743	    text = "\n".join(part for part in (result.stdout, result.stderr) if part)
   744	    text_cf = text.casefold()
   745	    if result.returncode == 0:
   746	        if "is not a record nor shared folder" in text_cf:
   747	            raise SmokeError(
   748	                f"share-add rejected folder {folder_uid} for app {app_uid}: "
   749	                f"sync/cache issue (keeper stdout). Try `keeper sync-down` then re-run smoke."
   750	            )
   751	        return
   752	    if "already" in text_cf:
   753	        log.info("KSM app %s already bound to folder %s", app_uid, folder_uid)
   754	        return
   755	    raise SmokeError(
   756	        f"share-add failed for app {app_uid} -> folder {folder_uid} (rc={result.returncode}); "
   757	        f"stderr={result.stderr!r} stdout_tail={text[-800:]!r}"
   758	    )
