   687	def _load_admin_creds(profile: identity.SmokeProfile | None = None) -> tuple[str, str, str]:
   688	    """Re-fetch admin creds via deploy_watcher.load_keeper_creds().
   689	
   690	    KeeperParams zeroes .password after successful login, so we can't pull
   691	    the password off admin_params. Re-reading from KSM is cheap (~1s) and
   692	    lets the smoke runner exercise either login-helper path without
   693	    plumbing secrets through identity.admin_login()'s return.
   694	    """
   695	    smoke_profile = profile if profile is not None else identity.DEFAULT_PROFILE
   696	    module_path = smoke_profile.deploy_watcher_path
   697	    deploy_watcher = identity._load_lab_module("sdk_smoke_admin_creds", module_path)
   698	    if hasattr(deploy_watcher, "ROOT"):
   699	        deploy_watcher.ROOT = smoke_profile.ksm_config.parent
   700	    email, password, totp_secret = deploy_watcher.load_keeper_creds()
   701	    return email, password, totp_secret
   702	
   703	
   704	def _load_admin_password(profile: identity.SmokeProfile | None = None) -> str:
   705	    return _load_admin_creds(profile)[1]
