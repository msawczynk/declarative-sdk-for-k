   152	        lock_path.unlink()
   153	    except FileNotFoundError:
   154	        log.info("smoke parallel-profile lock already missing: %s", lock_path)
   155	    except OSError as exc:
   156	        log.warning("could not release smoke parallel-profile lock %s: %s", lock_path, exc)
   157	    else:
   158	        log.info("released smoke parallel-profile lock %s", lock_path)
