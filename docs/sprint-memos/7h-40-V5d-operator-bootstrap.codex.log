   663	def _format_sdk_failure(
   664	    prefix: str,
   665	    *,
   666	    command: list[str],
   667	    returncode: int,
   668	    stdout_tail: str,
   669	    stderr_tail: str,
   670	) -> str:
   671	    return "\n".join(
   672	        [
   673	            f"{prefix}: exit_code={returncode}",
   674	            f"command: {_quote_cmd(command)}",
   675	            "stdout_tail:",
   676	            stdout_tail,
   677	            "stderr_tail:",
   678	            stderr_tail,
   679	        ]
   680	    )
