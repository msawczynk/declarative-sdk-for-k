     1	name: live-smoke
     2	
     3	# Manual-trigger only. Runs the live-tenant smoke loop against the
     4	# repo-secret-provided KSM record. Skipped on PRs and on push so a
     5	# malicious contributor can't trigger a live mutation.
     6	#
     7	# To run:
     8	#   gh workflow run live-smoke -f schema_family=pam-environment
     9	#
    10	# Required repo secrets (configure under Settings → Secrets):
    11	#   KEEPER_LIVE_KSM_RECORD_UID   UID of the bootstrap config record
    12	#   KEEPER_CONFIG_B64            base64-encoded commander config.json
    13	#                                (workflow decodes to $KEEPER_CONFIG path)
    14	#
    15	# Per docs/V2_DECISIONS.md Q4 the resulting transcript artefact gets
    16	# wired into a schema family's `x-keeper-live-proof.evidence` to graduate
    17	# it from `preview-gated` to `supported`.
    18	
    19	on:
    20	  workflow_dispatch:
    21	    inputs:
    22	      schema_family:
    23	        description: "schema family being proven (e.g. pam-environment)"
    24	        required: true
    25	        default: "pam-environment"
    26	      schema_version:
    27	        description: "schema version"
    28	        required: true
    29	        default: "v1"
    30	
    31	permissions:
    32	  contents: read
    33	
    34	jobs:
    35	  live-smoke:
    36	    name: live smoke (${{ inputs.schema_family }}.${{ inputs.schema_version }})
    37	    runs-on: ubuntu-latest
    38	    timeout-minutes: 20
    39	    env:
    40	      KEEPER_LIVE_TENANT: "1"
    41	      KEEPER_LIVE_KSM_RECORD_UID: ${{ secrets.KEEPER_LIVE_KSM_RECORD_UID }}
    42	    steps:
    43	      - uses: actions/checkout@v4
    44	      - uses: actions/setup-python@v5
    45	        with:
    46	          python-version: "3.11"
    47	      - name: install
    48	        run: |
    49	          python -m pip install --upgrade pip
    50	          pip install -e ".[dev]"
    51	      - name: materialise KEEPER_CONFIG
    52	        run: |
    53	          mkdir -p .live-smoke
    54	          printf '%s' "${{ secrets.KEEPER_CONFIG_B64 }}" | base64 -d > .live-smoke/config.json
    55	          echo "KEEPER_CONFIG=$PWD/.live-smoke/config.json" >> "$GITHUB_ENV"
    56	      - name: smoke manifest
    57	        run: |
    58	          cat > .live-smoke/manifest.yml <<'YAML'
    59	          schema: pam-environment.v1
    60	          identity:
    61	            tenant_alias: ci-live-smoke
    62	          YAML
    63	      - name: run live-smoke
    64	        env:
    65	          SCHEMA_FAMILY: ${{ inputs.schema_family }}
    66	          SCHEMA_VERSION: ${{ inputs.schema_version }}
    67	        run: |
    68	          mkdir -p evidence
    69	          dsk live-smoke \
    70	            --manifest .live-smoke/manifest.yml \
    71	            --workdir .live-smoke \
    72	            --evidence-out "evidence/${SCHEMA_FAMILY}.${SCHEMA_VERSION}.json" \
    73	            --schema-family "$SCHEMA_FAMILY" \
    74	            --schema-version "$SCHEMA_VERSION"
    75	      - name: post-run secret-leak grep (belt + braces)
    76	        run: |
    77	          if grep -RIE 'BEGIN (RSA )?PRIVATE KEY' evidence/; then
    78	            echo "::error::PEM block found in evidence file"
    79	            exit 1
    80	          fi
    81	          if grep -REn '\b[A-Fa-f0-9]{40,}\b' evidence/ ; then
    82	            echo "::error::long hex run found in evidence — possible leaked key"
    83	            exit 1
    84	          fi
    85	      - name: upload sanitized evidence
    86	        uses: actions/upload-artifact@v4
    87	        if: always()
    88	        with:
    89	          name: live-smoke-evidence-${{ inputs.schema_family }}-${{ inputs.schema_version }}
    90	          path: evidence/
    91	          if-no-files-found: error
    92	          retention-days: 30
    93	      - name: scrub workspace
    94	        if: always()
    95	        run: |
    96	          rm -rf .live-smoke

