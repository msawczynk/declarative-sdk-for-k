   600	def _sdk_allow(ok_codes: list[int], args: list[str], *, env: dict[str, str]) -> int:
   601	    cmd = [sys.executable, "-m", "keeper_sdk.cli", "--provider", "commander", *args]
   602	    log.info("SDK: %s", " ".join(cmd))
   603	    result = subprocess.run(
   604	        cmd,
   605	        cwd=ROOT,
   606	        env=env,
   607	        check=False,
   608	        capture_output=True,
   609	        text=True,
   610	        stdin=subprocess.DEVNULL,
   611	    )
   612	    if result.returncode not in ok_codes:
   613	        stdout_tail = _tail_text(result.stdout)
   614	        stderr_tail = _tail_text(result.stderr)
   615	        if result.returncode == 5:
   616	            raise TenantConstraintError(
   617	                _format_sdk_failure(
   618	                    "sdk command reported tenant/provider constraint",
   619	                    command=cmd,
   620	                    returncode=result.returncode,
   621	                    stdout_tail=stdout_tail,
   622	                    stderr_tail=stderr_tail,
   623	                )
   624	            )
   625	        raise SdkCommandError(
   626	            args=args,
   627	            command=cmd,
   628	            returncode=result.returncode,
   629	            stdout=result.stdout,
   630	            stderr=result.stderr,
   631	        )
   632	    if result.stdout:
   633	        log.debug("SDK stdout tail:\n%s", _tail_text(result.stdout))
   634	    if result.stderr:
   635	        log.debug("SDK stderr tail:\n%s", _tail_text(result.stderr))
   636	    return result.returncode
