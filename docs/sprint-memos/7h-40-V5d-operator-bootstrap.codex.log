   103	def _keepercommander_installed_tuple() -> tuple[int, ...]:
   104	    from importlib.metadata import PackageNotFoundError, version
   105	
   106	    try:
   107	        raw = version("keepercommander")
   108	    except PackageNotFoundError:
   109	        return ()
   110	    parts: list[int] = []
   111	    for segment in raw.strip().split("."):
   112	        digits = ""
   113	        for ch in segment:
   114	            if ch.isdigit():
   115	                digits += ch
   116	            else:
   117	                break
   118	        if not digits:
   119	            break
   120	        parts.append(int(digits))
   121	    return tuple(parts)
