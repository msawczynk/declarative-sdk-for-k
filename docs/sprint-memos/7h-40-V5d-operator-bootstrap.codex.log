   231	        _mark(state, "admin auth refreshed after identity bootstrap")
   232	    except Exception as exc:  # pragma: no cover - live-only path
   233	        raise PreflightError(f"auth bootstrap failed: {exc}") from exc
   234	
   235	    state["admin_params"] = admin_params
   236	    state["ident"] = ident
   237	
   238	    try:
