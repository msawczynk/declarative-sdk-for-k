   652	
   653	def main(argv: list[str] | None = None) -> int:
   654	    parser = argparse.ArgumentParser(description="Ensure SDK smoke identity for a profile user.")
   655	    parser.add_argument("--force", action="store_true", help="force TOTP re-enrollment")
   656	    parser.add_argument("--profile", default="default", help="smoke profile id")
   657	    args = parser.parse_args(argv)
   658	
   659	    profile = load_profile(args.profile)
   660	    ident = ensure_sdktest_identity(force_reenroll=args.force, profile=profile)
   661	    preview = hashlib.sha256(ident["totp_secret"].encode("utf-8")).hexdigest()
   662	    summary = {
   663	        "email": ident["email"],
   664	        "admin_record_uid": ident["admin_record_uid"],
   665	        "commander_config_path": ident["commander_config_path"],
   666	        "totp_secret_preview": f"sha256:{preview}",
   667	    }
   668	    print(json.dumps(summary, separators=(",", ":")))
   669	    return 0
   670	
   671	
   672	if __name__ == "__main__":
   673	    raise SystemExit(main())

